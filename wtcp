#!/usr/bin/env bash
# wtcp — Worktree Cockpit: run several coding agents on one prompt in an isolated
# tmux grid, then review, score, and merge the best (workmux + tmux + git).
#
# COMMANDS                              alias   in-grid key   what it does
#   wtcp start "<prompt>" [name]        b                     start a round: broadcast to every agent + build the grid
#   wtcp score                          r       prefix Ctrl-R compare all agents with an LLM: rank + winner (scores on borders + popup)
#   wtcp show                                                 show the last judge report popup
#   wtcp copy                           cp                    copy the last judge report to the clipboard
#   wtcp merge                          m       prefix Ctrl-R merge the JUDGE'S winner (scored 🏆/top-★) -> pick machinery, no menu
#   wtcp winner                                 prefix Ctrl-R menu: pick the winning agent (best score first) -> merge it
#   wtcp diff [name]                            prefix Ctrl-R view an agent's FULL diff vs the round base (focused pane, or menu)
#   wtcp pick [name] [merge flags]      p       prefix Ctrl-P merge the FOCUSED agent into the workmux main branch (auto-commit), drop the rest
#                                                             (a winner with NO code changes is KEPT as a live session instead of merged;
#                                                              pick/merge pass --squash/--rebase/--into <branch> through to workmux merge)
#   wtcp keep [name]                    k       prefix Ctrl-K keep ONE agent's live session (own window, no merge), drop the rest + grid
#   wtcp drop                           x       prefix Ctrl-X remove just the focused agent's pane (grid re-tiles)
#   wtcp send "<text>"                  s       prefix Ctrl-S send a follow-up line to every agent
#   wtcp fork "<prompt>"                f       prefix Ctrl-F start a new round from the focused agent's WIP (no merge)
#   wtcp abandon                        a                     discard the whole grid, merge nothing
#   wtcp grid                           g                     jump to the grid window
#   wtcp agents [names...]                                    show / set the agents compared (default: claude codex opencode)
#   wtcp list                           ls                    list active worktrees
#   wtcp clean                          clear                 remove ALL compare worktrees + close grid windows
#   wtcp setup                                                (re)install the in-grid keys + mouse (auto-run by `start`)
#   wtcp doctor                                               check tmux/mouse/agents/deps + print troubleshooting tips
#
# IN-GRID KEYS — press your tmux prefix, then:
#   Ctrl-P pick   ·   Ctrl-K keep   ·   Ctrl-X drop   ·   Ctrl-R review menu   ·   Ctrl-S send-all   ·   Ctrl-F fork
#   z = fullscreen the focused agent (z again to return)   ·   arrows = move · o = cycle
#   Ctrl-arrows = resize the focused agent (Alt-arrows = resize bigger steps)   ·   [ = scroll
#   (Use Ctrl+letter — it passes through the Korean IME. Mouse wheel scrolls; click selects a pane.)
#
# You usually only TYPE `wtcp start "..."`; everything else is the in-grid keys above.
# Config: ~/.config/wtcp/config  (COCKPIT_AGENTS, COCKPIT_JUDGE_URL, COCKPIT_JUDGE_MODEL, COCKPIT_TRUST, ...).
set -euo pipefail

# Load user config (agent set, endpoints, COCKPIT_TRUST, ...) before defaults.
WTCP_CONFIG="${WTCP_CONFIG:-$HOME/.config/wtcp/config}"
# shellcheck disable=SC1090
[ -f "$WTCP_CONFIG" ] && . "$WTCP_CONFIG" || true

: "${COCKPIT_AGENTS:=claude codex opencode}"
# Agents that workmux can't prompt-inject and that need wtcp to send the prompt
# via tmux send-keys. agy no longer needs this (it launches via a wrapper that
# loads the prompt itself), so this is empty by default.
: "${COCKPIT_SENDKEYS_AGENTS:=}"
: "${COCKPIT_SEND_DELAY:=0.4}"        # delay between paste and Enter (avoids codex submit race)
: "${COCKPIT_AGY_DELAY:=4}"           # wait before send-keys-delivering to a non-builtin agent
: "${COCKPIT_LAUNCH_TIMEOUT:=0}"      # seconds to wait for workmux windows; 0 = auto by agent count
# Live status on the grid pane borders (workmux's window-name icons are lost
# when the agent windows are joined into the grid, so wtcp tracks its own):
# ⚡ = output changed recently (agent working) · 💬 = quiet (waiting/done).
: "${COCKPIT_STATUS:=1}"              # 0 disables the watcher
: "${COCKPIT_STATUS_INTERVAL:=3}"     # seconds between polls
: "${COCKPIT_STATUS_IDLE:=6}"         # quiet for this long -> 💬
# OPT-IN: 1 = launch agents with their folder-trust/permission/sandbox bypass
# flags so a brand-new project auto-starts. This disarms approval/sandbox gates
# (the agents auto-approve all tool use) and edits the global workmux config, so
# it is OFF by default — set COCKPIT_TRUST=1 explicitly to enable.
: "${COCKPIT_TRUST:=0}"
WIN_PREFIX="wt"
BAR_HEIGHT=6
# Always-visible shortcut cheatsheet (shown on the command-bar pane border).
# Use Ctrl + the letter; the Ctrl variant passes through the Korean IME.
BAR_KEYS='wtcp ▸ command bar   —   prefix + Ctrl-P pick·merge / Ctrl-K keep / Ctrl-X drop / Ctrl-S send-all / Ctrl-F fork / Ctrl-R review menu   —   z fullscreen · [ scroll'
SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
# Path the keybindings call back through. Prefer `wtcp` on PATH; fall back to this
# script's absolute path. COCKPIT_INVOKE overrides (e.g. a wrapper command).
INVOKE="${COCKPIT_INVOKE:-$(command -v wtcp || echo "$SELF")}"

# Terminal styling for wtcp's own output. Colors only when the stream is a
# tty (pane/terminal) and NO_COLOR is unset — piped/captured output stays plain.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_TAG=$'\033[1;36m'; C_OK=$'\033[1;32m'; C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'; C_OFF=$'\033[0m'
else
  C_TAG=""; C_OK=""; C_DIM=""; C_BOLD=""; C_OFF=""
fi
if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then E_RED=$'\033[1;31m'; E_OFF=$'\033[0m'; else E_RED=""; E_OFF=""; fi
say(){ printf '%s %s\n' "${C_TAG}wtcp${C_OFF}" "$*"; }            # progress line
ok(){  printf '%s %s\n' "${C_OK}wtcp ✔${C_OFF}" "$*"; }           # completed action
die(){ printf '%s %s\n' "${E_RED}wtcp ✗${E_OFF}" "$*" >&2; exit 1; }
_sh_quote(){ printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"; }
if [ -n "${COCKPIT_INVOKE:-}" ]; then
  # COCKPIT_INVOKE is a shell command prefix, not necessarily a single path:
  # e.g. `env WTCP_CONFIG=... /path/to/wtcp`.
  INVOKE_CMD="$COCKPIT_INVOKE"
else
  INVOKE_CMD=$(_sh_quote "$INVOKE")
fi
# workmux goes interactive when its stdin is a TTY and can then BLOCK waiting for
# input — even with -f — e.g. for raw-string agents (created by COCKPIT_TRUST or
# used by agy) on `add`, and a select UI on `remove`. Run every workmux call with
# stdin closed so it stays non-interactive; spawned agents still get pane TTYs.
_wm(){ command workmux "$@" </dev/null; }
need_tmux(){ [ -n "${TMUX:-}" ] || die "run inside a tmux session"; }
need_repo(){ git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "run inside a git repository"; }
# Resolve the pane/window wtcp was INVOKED from. Prefer $TMUX_PANE (tmux sets
# it for every process inside a pane): with NO attached client (headless or
# scripted use), bare `tmux display -p` can resolve to a DIFFERENT pane/window
# than the caller's — pick/keep/abandon would then act on the wrong window.
# Keybindings (run-shell) and popups don't set TMUX_PANE; there an attached
# client exists, so the `display -p` fallback correctly gives the active pane.
_cur_pane(){
  if [ -n "${TMUX_PANE:-}" ] && tmux display -p -t "$TMUX_PANE" '#{pane_id}' 2>/dev/null; then return 0; fi
  tmux display -p '#{pane_id}'
}
_cur_win(){
  if [ -n "${TMUX_PANE:-}" ] && tmux display -p -t "$TMUX_PANE" '#{window_id}' 2>/dev/null; then return 0; fi
  tmux display -p '#{window_id}'
}
goto_root(){ local r; r=$(tmux show-options -wqv -t "$(_cur_win)" @cockpit_root 2>/dev/null || true); [ -n "$r" ] && cd "$r" || true; }
pane_wt(){ tmux show-options -pqv -t "$1" @worktree 2>/dev/null || true; }
# Type the prompt into a pane and submit it. codex leaves the text in the input
# box if Enter arrives right after the paste, so we delay between the two
# (harmless for claude/opencode).
_send_to_pane(){
  tmux send-keys -t "$1" -l -- "$2"
  sleep "$COCKPIT_SEND_DELAY"
  tmux send-keys -t "$1" Enter
}
_current_ref(){
  git symbolic-ref --quiet --short HEAD 2>/dev/null || git rev-parse --short HEAD
}
_agent_env_key(){
  printf '%s' "$1" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9' '_' | sed -E 's/^_+//; s/_+$//'
}
_agent_cmd(){
  local key var
  key=$(_agent_env_key "$1"); var="COCKPIT_AGENT_${key}_CMD"
  printf '%s' "${!var-}"
}
_agent_kind(){
  local a="$1" key var kind
  key=$(_agent_env_key "$a"); var="COCKPIT_AGENT_${key}_KIND"; kind="${!var-}"
  if [ -n "$kind" ]; then printf '%s' "$kind"; return 0; fi
  case "$a" in
    claude|claude-*|claude_*) printf 'claude' ;;
    codex|codex-*|codex_*)   printf 'codex' ;;
    agy|agy-*|agy_*)         printf 'agy' ;;
    *)                       printf '%s' "$a" ;;
  esac
}
_agent_model(){
  local key var
  key=$(_agent_env_key "$1"); var="COCKPIT_AGENT_${key}_MODEL"
  printf '%s' "${!var-}"
}
# The launch command wtcp writes into the workmux agent map for this alias:
#   1. COCKPIT_AGENT_<ALIAS>_CMD verbatim (env prefixes, alternate backends, ...)
#   2. else the alias kind's CLI (+ COCKPIT_TRUST flags) + `--model <_MODEL>`
#   3. else empty -> keep workmux's builtin default for the name
# agy is handled separately (prompt-loading wrapper) in _ensure_agent_configs.
_agent_launch_cmd(){
  local a="$1" cmd kind model base
  cmd=$(_agent_cmd "$a")
  if [ -n "$cmd" ]; then printf '%s' "$cmd"; return 0; fi
  kind=$(_agent_kind "$a"); model=$(_agent_model "$a")
  case "$kind" in
    claude) if [ "${COCKPIT_TRUST:-0}" = 1 ]; then base="${COCKPIT_CLAUDE_CMD:-claude --permission-mode auto}"; else base="claude"; fi ;;
    codex)  if [ "${COCKPIT_TRUST:-0}" = 1 ]; then base="${COCKPIT_CODEX_CMD:-codex --dangerously-bypass-approvals-and-sandbox}"; else base="codex"; fi ;;
    *)      base="$kind" ;;
  esac
  if [ -n "$model" ]; then printf '%s --model %s' "$base" "$model"; return 0; fi
  # No model override: only trust-mode claude/codex need a rewritten command.
  case "$kind" in
    claude|codex) [ "${COCKPIT_TRUST:-0}" = 1 ] && printf '%s' "$base" ;;
  esac
  return 0
}
# Absolute worktree path (workmux path -> fallback to <repo>__worktrees/<wt>).
_wt_path(){
  local p root; p=$(_wm path "$1" 2>/dev/null || true)
  if [ -z "$p" ] || [ ! -d "$p" ]; then
    root=$(tmux show-options -wqv -t "$(_cur_win)" @cockpit_root 2>/dev/null || true)
    [ -n "$root" ] && p="$(dirname "$root")/$(basename "$root")__worktrees/$1"
  fi
  # Must return 0 even when not found: callers use `path=$(_wt_path ...)` and a
  # non-zero status there aborts the whole script under `set -e` (was the cause
  # of `wtcp score` exiting 1 when a pane's worktree path couldn't be resolved).
  if [ -d "$p" ]; then printf '%s' "$p"; fi
  return 0
}
# Keep only [a-z0-9-] for a git-safe kebab name (stdin or $1). Capped at 28 chars.
_sanitize_slug(){
  local s="${1-$(cat)}"
  printf '%s' "$s" | tr 'A-Z' 'a-z' | tr -c 'a-z0-9-' '-' \
    | sed -E 's/-+/-/g; s/^-+//; s/-+$//' | cut -c1-28 | sed -E 's/-+$//'
}
# Prompt (any language) -> short english kebab branch name.
#   COCKPIT_NAMER: fm (Apple Intelligence, default, on-device) | mlx | off.
#   fm falls back to an OpenAI-compatible endpoint if configured, then ASCII.
: "${COCKPIT_JUDGE_URL:=}"
: "${COCKPIT_JUDGE_MODEL:=}"
: "${COCKPIT_NAMER:=fm}"
: "${COCKPIT_NAMER_URL:=${COCKPIT_JUDGE_URL}}"
: "${COCKPIT_NAMER_MODEL:=${COCKPIT_JUDGE_MODEL}}"
# Authorization header VALUE for hosted endpoints, e.g. "Bearer sk-...". Empty =
# no header (many local servers need none). NAMER inherits
# JUDGE's value by default, so setting COCKPIT_JUDGE_AUTH alone covers both.
: "${COCKPIT_JUDGE_AUTH:=}"
: "${COCKPIT_NAMER_AUTH:=${COCKPIT_JUDGE_AUTH}}"
# FM helper default: relative to this script (resolving symlinks), assets/fm-helper/...
_self_dir(){
  local s="$SELF"
  [ -L "$s" ] && s="$(readlink "$s")"
  case "$s" in /*) ;; *) s="$(cd "$(dirname "$SELF")" && pwd)/$s";; esac
  (cd "$(dirname "$s")" && pwd)
}
: "${COCKPIT_FM_HELPER:=$(_self_dir)/assets/fm-helper/wtcp-fm-helper}"
# Optional warm Apple-Intelligence endpoint (AgentDeck daemon, if running):
# COCKPIT_DAEMON_PORT -> ~/.agentdeck/daemon.json httpPort -> 9120. Best-effort;
# if nothing is listening, naming falls back to the FM binary, then the configured endpoint.
: "${COCKPIT_DAEMON_PORT:=}"
if [ -z "${COCKPIT_DAEMON_URL:-}" ]; then
  _p="${COCKPIT_DAEMON_PORT:-}"
  [ -n "$_p" ] || _p=$(jq -r '.httpPort // .port // empty' "$HOME/.agentdeck/daemon.json" 2>/dev/null || true)
  [ -n "$_p" ] || _p=9120
  COCKPIT_DAEMON_URL="http://127.0.0.1:$_p"
fi
_NAME_INSTR='Output ONLY a short lowercase kebab-case english git branch name, max 3 words, only a-z 0-9 and hyphens, no quotes, no explanation, no slashes, summarizing this task: '
_FM_SYS='You output only a short kebab-case git branch name and nothing else.'
_name_fm(){   # Apple Intelligence (FoundationModels)
  local out
  # 1) prefer the warm daemon helper — it's resident, so no ~7s cold start
  out=$(curl -s --max-time 12 "$COCKPIT_DAEMON_URL/generate" -H 'Content-Type: application/json' \
        -d "$(jq -nc --arg p "$_NAME_INSTR$1" --arg s "$_FM_SYS" '{prompt:$p,instructions:$s}')" \
        2>/dev/null | jq -r '.text // empty' 2>/dev/null || true)
  [ -n "$out" ] && { printf '%s' "$out"; return 0; }
  # 2) fallback: invoke the helper binary directly (cold start)
  [ -x "$COCKPIT_FM_HELPER" ] || return 0
  jq -nc --arg p "$_NAME_INSTR$1" --arg s "$_FM_SYS" '{id:1,prompt:$p,instructions:$s,temperature:0.2}' \
    | "$COCKPIT_FM_HELPER" 2>/dev/null | head -1 | jq -r '.text // empty' 2>/dev/null || true
}
_name_mlx(){
  local hdr=(); [ -n "${COCKPIT_NAMER_AUTH:-}" ] && hdr+=(-H "Authorization: $COCKPIT_NAMER_AUTH")
  [ -n "${COCKPIT_NAMER_URL:-}" ] || return 0
  curl -s --max-time 8 "$COCKPIT_NAMER_URL" -H 'Content-Type: application/json' ${hdr[@]+"${hdr[@]}"} \
    -d "$(jq -nc --arg p "$_NAME_INSTR$1" --arg m "${COCKPIT_NAMER_MODEL:-}" \
      '{messages:[{role:"user",content:$p}],max_tokens:20,temperature:0.2} + (if $m == "" then {} else {model:$m} end)')" \
    2>/dev/null | jq -r '.choices[0].message.content // empty' 2>/dev/null || true
}
slugify(){
  local prompt="$1" out=""
  case "$COCKPIT_NAMER" in
    fm)  out=$(_sanitize_slug "$(_name_fm "$prompt")"); [ -n "$out" ] || out=$(_sanitize_slug "$(_name_mlx "$prompt")");;
    mlx) out=$(_sanitize_slug "$(_name_mlx "$prompt")");;
    *)   out="";;
  esac
  [ -n "$out" ] || out=$(printf '%s' "$prompt" | _sanitize_slug)   # fallback: ASCII letters of the prompt
  [ -n "$out" ] && printf '%s' "$out" || printf 'task-%s' "$(date +%H%M%S)"
}

# Set/replace an agent's command in the workmux global agents map (idempotent).
# (workmux honors overrides of builtin names and appends the prompt as -- "...".)
_set_agent_cfg(){
  local CFG="$HOME/.config/workmux/config.yaml" agent="$1" cmd="$2" line esc
  mkdir -p "$(dirname "$CFG")"; [ -f "$CFG" ] || printf 'nerdfont: true\n' > "$CFG"
  esc="${cmd//\\/\\\\}"; esc="${esc//\"/\\\"}"
  line="  $agent: \"$esc\""
  if grep -qE "^[[:space:]]*$agent:" "$CFG"; then
    awk -v a="$agent" -v w="$line" 'index($0,a":") && $0 ~ "^[[:space:]]*"a":" {print w; next} {print}' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
  elif grep -qE '^agents:' "$CFG"; then
    awk -v w="$line" '/^agents:/&&!d{print;print w;d=1;next}{print}' "$CFG" > "$CFG.tmp" && mv "$CFG.tmp" "$CFG"
  else
    printf '\nagents:\n%s\n' "$line" >> "$CFG"
  fi
}

# Configure the agents in the set so a round launches cleanly:
#  - agy: a wrapper that loads the prompt from .workmux/PROMPT-*.md (it can't take
#    workmux's `-- "..."` form) and runs `agy -i`. The wrapper is always installed
#    (prompt delivery); COCKPIT_TRUST only adds agy's permission-bypass flag.
#  - claude/codex: when COCKPIT_TRUST=1, launch in an unattended permission mode.
#    The "Do you trust this folder?" dialog is skipped separately by _pretrust
#    (seeding each agent's own trust store), NOT by these flags. Defaults:
#      claude -> auto mode (asks like normal, just doesn't stop the round)
#      codex  -> bypass approvals+sandbox
#    Override per agent with COCKPIT_CLAUDE_CMD / COCKPIT_CODEX_CMD.
#  - opencode: left as the builtin (no trust prompt).
# Note: this edits the workmux GLOBAL config, so it also affects plain `workmux
# -a claude/codex`. Set COCKPIT_TRUST=0 (default) to keep the safety prompts.
_ensure_agent_configs(){
  local a flag="" kind cmd
  [ "${COCKPIT_TRUST:-0}" = 1 ] && flag="--dangerously-skip-permissions "
  for a in $COCKPIT_AGENTS; do
    kind=$(_agent_kind "$a")
    if [ "$kind" = agy ] && [ -z "$(_agent_cmd "$a")" ]; then
      local W="$HOME/.config/wtcp/agy-wm"; mkdir -p "$(dirname "$W")"
      printf '#!/bin/sh\np=$(cat .workmux/PROMPT-*.md 2>/dev/null)\nexec agy %s-i "$p"\n' "$flag" > "$W"; chmod +x "$W"
      _set_agent_cfg "$a" "$W"
      continue
    fi
    cmd=$(_agent_launch_cmd "$a")
    [ -n "$cmd" ] && _set_agent_cfg "$a" "$cmd"
  done
  return 0
}

# COCKPIT_TRUST also pre-seeds each agent's own folder-trust store for the
# worktree it will open, so a brand-new project doesn't stop at "Do you trust
# this folder?". (The --dangerously-* flags only auto-approve tool use, NOT this
# separate dialog.) claude + codex are seeded; agy's store lives under ~/.gemini
# — shared with the Google OAuth token — so it is left to a one-time manual accept.
_trust_codex(){   # $1 = repo root (codex scopes trust to the repository root)
  local cfg="$HOME/.codex/config.toml" p="$1"
  [ -d "$(dirname "$cfg")" ] || return 0
  [ -f "$cfg" ] || : > "$cfg"
  grep -qF "[projects.\"$p\"]" "$cfg" 2>/dev/null && return 0   # already trusted
  printf '\n[projects."%s"]\ntrust_level = "trusted"\n' "$p" >> "$cfg"
}
_trust_claude(){  # $1 = worktree path (claude trusts the project cwd)
  local cfg="$HOME/.claude.json" p="$1" tmp
  [ -f "$cfg" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  tmp="$cfg.wtcp-tmp"
  jq --arg p "$p" '.projects[$p] = ((.projects[$p] // {}) + {hasTrustDialogAccepted:true, hasTrustDialogBashAccepted:true})' "$cfg" > "$tmp" 2>/dev/null \
    && mv "$tmp" "$cfg" || rm -f "$tmp"
}
_pretrust(){      # $1 = task  $2 = repo root
  [ "${COCKPIT_TRUST:-0}" = 1 ] || return 0
  local task="$1" root="$2" a kind wtbase
  wtbase="$(dirname "$root")/$(basename "$root")__worktrees"
  for a in $COCKPIT_AGENTS; do
    kind=$(_agent_kind "$a")
    case "$kind" in
    codex)  _trust_codex "$root" ;;
    claude) _trust_claude "$wtbase/$task-$a" ;;
  esac; done
  return 0
}

# tmux layout checksum (pure bash; ord via printf "%d 'c").
_layout_checksum(){
  local s="$1" c=0 i ch o
  for (( i=0; i<${#s}; i++ )); do
    ch="${s:i:1}"; printf -v o '%d' "'$ch"
    c=$(( (c>>1) + ((c&1)<<15) )); c=$(( (c + o) & 0xffff ))
  done
  printf '%04x' "$c"
}
# Distribute T cells across K parts with K-1 one-cell dividers between them.
_split_sizes(){
  local T="$1" K="$2" content base rem i out=""
  content=$(( T - (K-1) )); base=$(( content / K )); rem=$(( content % K ))
  for (( i=0; i<K; i++ )); do out="$out $(( base + (i<rem ? 1 : 0) ))"; done
  printf '%s' "${out# }"
}
# Lay the grid window's panes out as a rows x cols grid (row-major; tmux fills
# cells in pane-index order). Trailing blank pads were created last so they land
# in the final cells. Falls back to tiled on a count mismatch / error.
_apply_grid_layout(){
  local cwin="$1" rows="$2" cols="$3" W H geo cs
  local arr=(); while IFS= read -r p; do arr+=("${p#%}"); done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  local n=${#arr[@]}
  (( n >= 2 )) || return 0
  if (( n != rows*cols )); then tmux select-layout -t "$cwin" tiled 2>/dev/null || true; return 0; fi
  read -r W H < <(tmux display -p -t "$cwin" '#{window_width} #{window_height}')
  local CW CH CX CY x=0 y=0 r c k=0 cells body=""
  read -ra CW <<< "$(_split_sizes "$W" "$cols")"
  read -ra CH <<< "$(_split_sizes "$H" "$rows")"
  CX=(); for (( c=0; c<cols; c++ )); do CX[c]=$x; x=$(( x + CW[c] + 1 )); done
  CY=(); for (( r=0; r<rows; r++ )); do CY[r]=$y; y=$(( y + CH[r] + 1 )); done
  if (( rows == 1 )); then
    cells=""; for (( c=0; c<cols; c++ )); do
      cells="${cells}${cells:+,}${CW[c]}x${H},${CX[c]},0,${arr[k]}"; k=$((k+1)); done
    geo="${W}x${H},0,0{${cells}}"
  else
    for (( r=0; r<rows; r++ )); do
      cells=""; for (( c=0; c<cols; c++ )); do
        cells="${cells}${cells:+,}${CW[c]}x${CH[r]},${CX[c]},${CY[r]},${arr[k]}"; k=$((k+1)); done
      if (( cols == 1 )); then body="${body}${body:+,}${cells}"
      else body="${body}${body:+,}${W}x${CH[r]},0,${CY[r]}{${cells}}"; fi
    done
    geo="${W}x${H},0,0[${body}]"
  fi
  cs=$(_layout_checksum "$geo")
  tmux select-layout -t "$cwin" "${cs},${geo}" 2>/dev/null || tmux select-layout -t "$cwin" tiled 2>/dev/null || true
}

# Grid assembly timed out with agents missing. Don't auto-destroy what DID
# launch: worktrees are created sequentially and slow project hooks routinely
# outlive the timeout (gotcha #3), so the missing windows may be seconds away
# and the launched agents may already be mid-work. Default to keeping.
_launch_timeout_bail(){   # $1=task $2=found windows ("<win> <worktree>" lines) $3=expected $4=timeout_s
  local task="$1" found="$2" nag="$3" timeout_s="$4" a
  {
    echo "wtcp: expected $nag worktree windows for '$task', found $(printf '%s\n' "$found" | grep -c . || true) after ${timeout_s}s:"
    for a in $COCKPIT_AGENTS; do
      if printf '%s\n' "$found" | grep -q " $task-$a\$"; then
        echo "    $a: launched"
      else
        echo "    $a: MISSING"
      fi
    done
    echo "wtcp: likely causes: agent CLI not installed/authenticated, a custom agent name missing"
    echo "  from ~/.config/workmux/config.yaml, or slow worktree hooks (raise COCKPIT_LAUNCH_TIMEOUT)."
    echo "  Run 'wtcp doctor' to check the environment."
    printf "  [k] keep what launched (inspect/retry)  ·  [c] clean this round's worktrees now? [k/c] "
  } >&2
  local ans=""; read -r ans </dev/tty 2>/dev/null || ans=k   # headless -> keep (no work lost)
  case "$ans" in
    c|C) _clean_task "$task"; echo "wtcp: removed '$task-*' worktrees" >&2;;
    *)   echo "wtcp: kept. Clean up later with 'wtcp clean', or retry once the missing agent is fixed." >&2;;
  esac
  die "round '$task' did not fully launch"
}

# Window chrome for grid/kept windows: heavy dim pane borders with a bright
# active border, labels on top. This is what makes the separators visible —
# including the line between the agent grid and the bottom command bar (the
# bar's label is highlighted so the bar doesn't read as just another log pane).
_style_window(){   # $1=window id
  local w="$1"
  tmux set-window-option -t "$w" pane-border-status top 2>/dev/null || true
  tmux set-window-option -t "$w" pane-border-format ' #{?#{@cockpit_bar},#[fg=colour45]#[bold],#[bold]}#{@pane_label}#{?#{@cockpit_status}, #{@cockpit_status},} #[default]' 2>/dev/null || true
  tmux set-window-option -t "$w" pane-border-lines heavy 2>/dev/null || true
  tmux set-window-option -t "$w" pane-border-style 'fg=colour240' 2>/dev/null || true
  tmux set-window-option -t "$w" pane-active-border-style 'fg=colour45' 2>/dev/null || true
}

# Live per-pane agent status for a grid/kept window. Joining the agent windows
# into the grid destroys workmux's own window-name status icons, so wtcp polls
# each agent pane's recent output: changed since last poll -> ⚡ (working),
# quiet for COCKPIT_STATUS_IDLE seconds -> 💬 (waiting for input / done). The
# icon is stored in the pane's @cockpit_status and rendered by _style_window's
# border format. One watcher per window (pid in @cockpit_watch); it exits by
# itself when the window disappears (pick/keep/abandon/clean).
cmd_status_watch(){
  local w="${1:-}"; [ -n "$w" ] || die 'status-watch <window-id>'
  local existing; existing=$(tmux show-options -wqv -t "$w" @cockpit_watch 2>/dev/null || true)
  if [ -n "$existing" ] && kill -0 "$existing" 2>/dev/null; then return 0; fi
  tmux set-option -w -t "$w" @cockpit_watch "$$" 2>/dev/null || return 0
  local p wt h prev seen now st
  while tmux list-panes -t "$w" >/dev/null 2>&1; do
    now=$(date +%s)
    while IFS= read -r p; do
      wt=$(pane_wt "$p"); [ -n "$wt" ] || continue
      # Hash the WHOLE visible pane: capture-pane pads the viewport with
      # trailing blank lines, so a `tail -n` sample would hash constant blanks
      # while the real content changes further up.
      h=$(tmux capture-pane -p -t "$p" 2>/dev/null | cksum 2>/dev/null || true)
      prev=$(tmux show-options -pqv -t "$p" @cockpit_hash 2>/dev/null || true)
      if [ "$h" != "$prev" ]; then
        tmux set-option -p -t "$p" @cockpit_hash "$h" 2>/dev/null || true
        tmux set-option -p -t "$p" @cockpit_seen "$now" 2>/dev/null || true
        st="⚡"
      else
        seen=$(tmux show-options -pqv -t "$p" @cockpit_seen 2>/dev/null || true)
        [ -n "$seen" ] || seen=$now
        if [ $(( now - seen )) -ge "$COCKPIT_STATUS_IDLE" ]; then st="💬"; else st="⚡"; fi
      fi
      [ "$(tmux show-options -pqv -t "$p" @cockpit_status 2>/dev/null || true)" = "$st" ] \
        || tmux set-option -p -t "$p" @cockpit_status "$st" 2>/dev/null || true
    done < <(tmux list-panes -t "$w" -F '#{pane_id}' 2>/dev/null || true)
    sleep "$COCKPIT_STATUS_INTERVAL"
  done
}
# Detached spawn: the spawner often dies moments later (keep/pick kill the
# very pane that ran them), and tmux HUPs the pane's whole process group — so
# double-fork AND nohup, or the watcher dies with its parent.
_spawn_status_watch(){   # $1=window id
  [ "${COCKPIT_STATUS:-1}" = 1 ] || return 0
  ( nohup env WTCP_CONFIG="$WTCP_CONFIG" "$SELF" status-watch "$1" >/dev/null 2>&1 & ) 2>/dev/null || true
}

# Banner printed at the top of the command-bar pane (it runs in the pane's tty,
# so colors are always on). Distinguishes the bar from agent output at a glance.
cmd_bar_banner(){
  local T=$'\033[1;36m' D=$'\033[2m' B=$'\033[1m' O=$'\033[0m'
  printf '%s\n' \
    "${T}◤ wtcp command bar${O}${D} — a normal shell: type wtcp commands here (their logs show here too)${O}" \
    "  ${B}keys${O}  prefix + ${B}Ctrl-P${O} pick·merge ${D}│${O} ${B}Ctrl-K${O} keep ${D}│${O} ${B}Ctrl-X${O} drop ${D}│${O} ${B}Ctrl-S${O} send-all ${D}│${O} ${B}Ctrl-F${O} fork ${D}│${O} ${B}Ctrl-R${O} review menu" \
    "  ${B}cli ${O}  wtcp score ${D}│${O} merge ${D}│${O} keep ${D}│${O} send \"...\" ${D}│${O} fork \"...\" ${D}│${O} diff ${D}│${O} abandon ${D}│${O} help"
}

# One round: branch N agents from base + broadcast prompt + assemble grid.
_run_round(){
  local prompt="$1" task="$2" base="${3:-}"
  _ensure_agent_configs   # agy wrapper + (COCKPIT_TRUST) tool-approval bypass flags for claude/codex
  local root; root=$(git rev-parse --show-toplevel)
  local round_base; round_base="${base:-$(_current_ref)}"
  _pretrust "$task" "$root"   # (COCKPIT_TRUST) pre-trust the claude/codex worktrees so they auto-start
  local addargs=(); for a in $COCKPIT_AGENTS; do addargs+=(-a "$a"); done
  [ -n "$base" ] && addargs+=(--base "$base")

  local nag neww found_count add_status=0 timeout_s deadline now
  nag=0; for a in $COCKPIT_AGENTS; do nag=$((nag+1)); done
  say "'$task' -> [$COCKPIT_AGENTS]${base:+ (base: $base)} launching..."
  _wm add "$task" "${addargs[@]}" -p "$prompt" -b >/dev/null || add_status=$?
  [ "$add_status" -eq 0 ] || say "workmux add returned $add_status; waiting for launched windows..."
  # workmux creates each worktree sequentially and project hooks can make cold
  # worktrees slow, so poll until all agent windows appear. Some successful
  # launches still return non-zero (for example CLI notifier hooks); the window
  # poll below is the source of truth.
  timeout_s="${COCKPIT_LAUNCH_TIMEOUT:-0}"
  case "$timeout_s" in ''|*[!0-9]*) timeout_s=0 ;; esac
  [ "$timeout_s" -gt 0 ] || timeout_s=$(( nag * 60 + 30 ))
  deadline=$(( $(date +%s) + timeout_s ))
  while :; do
    neww=$(_find_task_windows "$task")
    found_count=$(printf '%s\n' "$neww" | grep -c . || true)
    [ "$found_count" -ge "$nag" ] && break
    now=$(date +%s); [ "$now" -ge "$deadline" ] && break
    sleep 1
  done
  [ "${found_count:-0}" -eq "$nag" ] || _launch_timeout_bail "$task" "$neww" "$nag" "$timeout_s"

  # Grid window: pull each agent pane in with join-pane (pane_id is stable across the move).
  local cwin ph
  cwin=$(tmux new-window -d -P -F '#{window_id}' -n "${WIN_PREFIX}:${task}")
  ph=$(tmux list-panes -t "$cwin" -F '#{pane_id}' | head -1)
  tmux set-option -w -t "$cwin" @cockpit_root "$root"
  tmux set-option -w -t "$cwin" @cockpit_prompt "$prompt"   # used as the pick auto-commit message
  tmux set-option -w -t "$cwin" @cockpit_base "$round_base"  # used as the judge diff base
  local apanes=() join_lines=() line idx
  while IFS= read -r line; do [ -n "$line" ] && join_lines+=("$line"); done <<< "$neww"
  # join-pane inserts each joined pane before the existing panes in this tmux
  # layout, so join in reverse to make pane-index order match COCKPIT_AGENTS.
  for (( idx=${#join_lines[@]}-1; idx>=0; idx-- )); do
    IFS=' ' read -r w wt <<< "${join_lines[idx]}"
    [ -n "$w" ] || continue
    local src
    src=$(tmux list-panes -t "$w" -F '#{pane_id}' | head -1)
    tmux join-pane -d -s "$src" -t "$cwin"
    # Re-tile after each join: join-pane stacks vertically, so without this the
    # 5th/6th pane gets "create pane failed: pane too small". Tiling keeps panes
    # balanced (and large enough) during assembly; final shape set below.
    tmux select-layout -t "$cwin" tiled 2>/dev/null || true
    tmux set-option -p -t "$src" @worktree "$wt"
    tmux set-option -p -t "$src" @pane_label "$wt"
    apanes+=("$src")
  done
  tmux kill-pane -t "$ph" 2>/dev/null || true
  tmux select-layout -t "$cwin" tiled 2>/dev/null || true
  # Grid shape: 2/3 agents -> one row; 4-6 -> two rows. cols = ceil(N/rows).
  # Pad the trailing cells (only N=5 needs one) with blank panes, created last so
  # they fill the final (bottom-right) cells.
  local N=${#apanes[@]} grows gcols j pad lastp
  if (( N <= 3 )); then grows=1; else grows=2; fi
  gcols=$(( (N + grows - 1) / grows ))
  for (( j=N; j<grows*gcols; j++ )); do
    lastp=$(tmux list-panes -t "$cwin" -F '#{pane_id}' | tail -1)
    pad=$(tmux split-window -d -t "$lastp" -P -F '#{pane_id}' "clear; exec cat")
    tmux set-option -p -t "$pad" @pane_label "(empty)"
  done
  _apply_grid_layout "$cwin" "$grows" "$gcols"
  # Full-width bottom command bar (grid compresses above it; it survives drops).
  local bar
  bar=$(tmux split-window -d -f -v -l "$BAR_HEIGHT" -t "$cwin" -P -F '#{pane_id}' \
        "$INVOKE_CMD bar-banner; exec \${SHELL:-/bin/zsh}")
  tmux set-option -p -t "$bar" @cockpit_bar 1
  # Always-visible cheatsheet: pane-border line shows the keys on the bar and the
  # worktree name on each agent pane (score later augments these with ★ scores).
  _style_window "$cwin"
  tmux set-option -p -t "$bar" @pane_label "$BAR_KEYS"
  # Non-builtin agents (agy, etc.) aren't prompt-injected by workmux -p -> deliver via send-keys.
  local sa p wt
  for sa in $COCKPIT_SENDKEYS_AGENTS; do
    while IFS=' ' read -r p wt; do
      case "$wt" in *-"$sa") sleep "$COCKPIT_AGY_DELAY"; _send_to_pane "$p" "$prompt";; esac
    done < <(tmux list-panes -t "$cwin" -F '#{pane_id} #{@worktree}')
  done
  tmux select-pane -t "$bar"
  tmux select-window -t "$cwin"
  _spawn_status_watch "$cwin"
  ok "grid ready."
}

# True if any `<task>-<agent>` branch already exists (collision).
_task_collides(){
  local a
  for a in $COCKPIT_AGENTS; do
    git show-ref --verify --quiet "refs/heads/$1-$a" && return 0
  done
  return 1
}
# Next free name by appending -2, -3, ... until no collision.
_free_task(){
  local base="$1" t="$1" i=1
  while _task_collides "$t"; do i=$((i+1)); t="$base-$i"; done
  printf '%s' "$t"
}
# Remove the existing `<task>-<agent>` worktrees so the name can be reused.
_clean_task(){
  local a
  for a in $COCKPIT_AGENTS; do _wm remove "$1-$a" -f 2>/dev/null || true; done
}
_find_task_windows(){   # $1 = task; prints "<window-id> <worktree>" in COCKPIT_AGENTS order
  local task="$1" a want w name wt found
  for a in $COCKPIT_AGENTS; do
    want="$task-$a"; found=""
    while IFS= read -r w; do
      [ -n "$w" ] || continue
      name=$(tmux display-message -p -t "$w" '#{window_name}' 2>/dev/null || true)
      wt="${name##* }"
      case "$name" in
        "$want"|wm-"$want"|*" $want"|*" wm-$want") found="$w"; break ;;
      esac
      case "$wt" in
        "$want"|wm-"$want") found="$w"; break ;;
      esac
    done < <(tmux list-windows -F '#{window_id}')
    [ -n "$found" ] && printf '%s %s\n' "$found" "$want"
  done
  # Must return 0 even when the LAST agent's window is missing: the `[ -n ] &&`
  # above would otherwise be this function's exit status, and callers assign
  # `neww=$(_find_task_windows ...)` under `set -e` — a non-zero status there
  # killed `wtcp start` SILENTLY instead of reaching the launch-timeout path
  # (same class of bug as _wt_path above).
  return 0
}
# On collision, ask the user what to do. Sets global RESOLVED_TASK (or aborts).
# Defaults to auto-rename when there's no TTY (non-interactive).
_resolve_task(){
  RESOLVED_TASK="$1"
  _task_collides "$1" || return 0
  printf "wtcp: worktrees for '%s-*' already exist.\n  [n] new auto-named name  ·  [c] clean existing & reuse  ·  [a] abort? [n/c/a] " "$1" >&2
  local ans=""; read -r ans </dev/tty 2>/dev/null || ans=n
  case "$ans" in
    c|C) _clean_task "$1"; echo "wtcp: cleaned existing, reusing '$1'" >&2;;
    a|A) die "aborted";;
    *)   RESOLVED_TASK=$(_free_task "$1"); echo "wtcp: name in use -> using '$RESOLVED_TASK'" >&2;;
  esac
}

cmd_broadcast(){
  need_tmux; need_repo
  local nck=0 a; for a in $COCKPIT_AGENTS; do nck=$((nck+1)); done
  [ "$nck" -le 6 ] || die "at most 6 agents are supported (COCKPIT_AGENTS has $nck) — edit ~/.config/wtcp/config"
  cmd_setup   # install keybindings + mouse/scroll (idempotent) so `wtcp start` alone is enough
  local prompt="${1:-}"; [ -n "$prompt" ] || die 'start "<prompt>" [name]'
  local task="${2:-}"; [ -n "$task" ] || task=$(slugify "$prompt"); [ -n "$task" ] || task="t$(date +%H%M%S)"
  _resolve_task "$task"; task="$RESOLVED_TASK"
  _run_round "$prompt" "$task" ""
}

# Branch a new round from the focused agent's unmerged WIP.
cmd_fork(){
  need_tmux; need_repo
  local prompt="${1:-}"; [ -n "$prompt" ] || die 'fork "<prompt>" [name]'
  local fp wt; fp=$(_cur_pane); wt=$(pane_wt "$fp")
  [ -n "$wt" ] || die "put the cursor on the agent pane to fork from (not the bar/empty pane)"
  goto_root
  local wpath; wpath=$(_wm path "$wt" 2>/dev/null || true)
  if [ -n "$wpath" ] && [ -n "$(git -C "$wpath" status --porcelain 2>/dev/null)" ]; then
    say "committing [$wt] WIP (pinning the fork base)..."
    git -C "$wpath" add -A && git -C "$wpath" commit -q -m "wip: fork base from $wt" || true
  fi
  local task; task=$(slugify "$prompt"); [ -n "$task" ] || task="t$(date +%H%M%S)"
  _resolve_task "$task"; task="$RESOLVED_TASK"
  say "forking from [$wt] -> new round"
  _run_round "$prompt" "$task" "$wt"
}

# Discard the current grid (review-only round, no merge). Removes worktrees + closes window.
cmd_abandon(){
  need_tmux
  local cwin; cwin=$(_cur_win)
  goto_root
  local p wt
  while IFS= read -r p; do
    wt=$(pane_wt "$p"); [ -n "$wt" ] && (_wm remove "$wt" -f || true)
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  ok "grid abandoned (nothing merged)."
  # LAST on purpose (see _keep_session). Only kill a wtcp-owned (wt:*) window —
  # abandoning from a plain shell window must not destroy that window.
  case "$(tmux display -p -t "$cwin" '#{window_name}' 2>/dev/null)" in
    "${WIN_PREFIX}:"*) tmux kill-window -t "$cwin" 2>/dev/null || true ;;
    *) say "(not inside a wtcp grid window — nothing to close)" ;;
  esac
}

# ===== Built-in judge =====
# Calls a configured OpenAI-compatible LLM endpoint to
# score each agent's work and explain why, on demand, from the diff + the agent's
# recent output. COCKPIT_JUDGE_URL overrides the endpoint; COCKPIT_JUDGE_AUTH
# adds an Authorization header for hosted endpoints.
: "${COCKPIT_JUDGE_URL:=}"
: "${COCKPIT_JUDGE_MODEL:=}"
# The judge sees as much context as fits its window: the full diff + the agent's
# whole pane scrollback, each capped by these budgets (raise for a bigger-context
# judge model; lower for a small local one). char ~ 1/3-1/4 token.
: "${COCKPIT_JUDGE_OUTPUT_CHARS:=16000}"   # tail of each agent's terminal output
: "${COCKPIT_JUDGE_DIFF_CHARS:=16000}"     # diff vs round base
: "${COCKPIT_JUDGE_TIMEOUT:=120}"          # seconds per judge request (more context = slower)
: "${COCKPIT_POPUP_WIDTH:=92%}"
: "${COCKPIT_POPUP_HEIGHT:=85%}"
: "${COCKPIT_NO_INTERACTIVE_MENUS:=0}"
# Comparative scoring (wtcp score) sends ALL agents in one call; this is the
# TOTAL evidence budget split across them (per-agent = this / (agents*2)), kept
# small enough to fit the judge's context. Raise for a bigger-context model.
: "${COCKPIT_JUDGE_COMPARE_CHARS:=48000}"

_diff_base(){   # $1=worktree path $2=requested base -> validated base ref (fallback main/master)
  local path="$1" base="${2:-}"
  if [ -n "$base" ] && ! git -C "$path" rev-parse --verify -q "$base^{commit}" >/dev/null 2>&1; then
    base=""
  fi
  if [ -z "$base" ]; then
    base=main; git -C "$path" rev-parse --verify -q main >/dev/null 2>&1 || base=master
  fi
  printf '%s' "$base"
}
_wt_diff_raw(){   # $1=worktree path $2=base ref $3=color(never|always) -> FULL diff vs base (tracked + untracked new files), uncapped
  local path="$1" base f color="${3:-never}"
  base=$(_diff_base "$path" "${2:-}")
  git -C "$path" diff --color="$color" "$base" 2>/dev/null || true
  while IFS= read -r -d '' f; do
    printf '\n--- new file: %s ---\n' "$f"
    # --no-index exits 1 when the files differ (always, here) — not an error.
    git -C "$path" diff --no-index --color="$color" -- /dev/null "$path/$f" 2>/dev/null || true
  done < <(git -C "$path" ls-files -z --others --exclude-standard 2>/dev/null)
}
_wt_diff(){   # judge evidence: plain diff capped to the judge's budget
  _wt_diff_raw "$1" "${2:-}" never | head -c "$COCKPIT_JUDGE_DIFF_CHARS"
}

_judge_one(){   # $1=path $2=task prompt $3=pane_id $4=base ref -> "score|reason|model"
  local path="$1" prompt="$2" pane="$3" base="${4:-}" diff out req raw resp model score reason
  local jhdr=(); [ -n "${COCKPIT_JUDGE_AUTH:-}" ] && jhdr+=(-H "Authorization: $COCKPIT_JUDGE_AUTH")
  [ -n "$path" ] && diff=$(_wt_diff "$path" "$base") || diff=""
  # Whole pane scrollback (history-limit is raised in setup), trimmed to budget.
  out=$(tmux capture-pane -p -S - -t "$pane" 2>/dev/null | tail -c "$COCKPIT_JUDGE_OUTPUT_CHARS")
  req=$(jq -nc --arg t "${prompt:-(unknown task)}" --arg d "${diff:-(none)}" --arg o "$out" --arg m "${COCKPIT_JUDGE_MODEL:-}" \
    '{messages:[{role:"user",content:("You are a rigorous, skeptical senior engineer reviewing ONE agent'"'"'s attempt at the task below. Score 0-10: 10 = thorough and correct, 7-8 = solid with gaps, 5 = mediocre/partial, 0-3 = wrong, hand-wavy, or unfinished. Be calibrated and discriminating: reserve 9-10 for genuinely complete, correct, well-reasoned work, and penalize incorrect claims, vagueness, or work left undone. Judge on correctness, completeness, depth, and actionability. Evaluate BOTH evidence streams: the code Diff is the source of truth for implementation quality when present, while terminal Output is evidence for tests run, claims made, analysis quality, and whether the agent noticed important issues. If the Diff is empty, judge the substance and accuracy of the Output instead; do NOT penalize an empty diff by itself. Do not reward or penalize the agent for answering in Korean vs English unless the task explicitly requires a language. Base your judgement only on the evidence shown. Return STRICT JSON only: {\"score\":N,\"reason\":\"one concise bullet-fragment style reason naming what was strong and what was missing or wrong\"}. Write the \"reason\" value in the SAME LANGUAGE as the Task below; keep the JSON keys in English.\nTask: " + $t + "\n\nDiff vs base (may be empty):\n" + $d + "\n\nAgent terminal output:\n" + $o)}],max_tokens:400,temperature:0.2} + (if $m == "" then {} else {model:$m} end)')
  raw=$(curl -s --max-time "$COCKPIT_JUDGE_TIMEOUT" "$COCKPIT_JUDGE_URL" -H 'Content-Type: application/json' ${jhdr[@]+"${jhdr[@]}"} -d "$req" 2>/dev/null || true)
  model=$(printf '%s' "$raw" | jq -r '.model // empty' 2>/dev/null || true)
  resp=$(printf '%s' "$raw" | jq -r '.choices[0].message.content // empty' 2>/dev/null || true)
  score=$(printf '%s' "$resp" | jq -r '.score // empty' 2>/dev/null || true)
  reason=$(printf '%s' "$resp" | jq -r '.reason // empty' 2>/dev/null || true)
  if [ -z "$score" ]; then   # model wrapped JSON in prose — extract best-effort
    score=$(printf '%s' "$resp" | grep -oE '"score"[: ]*[0-9.]+' | grep -oE '[0-9.]+' | head -1)
    reason=$(printf '%s' "$resp" | sed -n 's/.*"reason"[: ]*"\([^"]*\)".*/\1/p' | head -1)
  fi
  printf '%s|%s|%s' "${score:-?}" "${reason:-(no judgment — is the judge LLM running?)}" "${model:-(unknown)}"
}

_judge_file(){ printf '%s' "$HOME/.config/wtcp/judge.txt"; }
_diff_file(){ printf '%s' "$HOME/.config/wtcp/diff.txt"; }
# Full-diff popup for one agent worktree: the judge only sees a capped diff,
# the user gets the WHOLE thing. Renders through delta when on PATH (it
# colorizes plain diff itself), else colorized git diff + less.
_show_diff_popup(){   # $1=worktree name
  local wt="$1" path base F qF body pager color
  path=$(_wt_path "$wt")
  if [ -z "$path" ]; then
    tmux display-message "wtcp: no worktree path for [$wt]" 2>/dev/null || true
    echo "wtcp: no worktree path for [$wt]" >&2; return 1
  fi
  base=$(tmux show-options -wqv -t "$(_cur_win)" @cockpit_base 2>/dev/null || true)
  if command -v delta >/dev/null 2>&1; then
    # Force delta's pager to plain `less -R`: its default includes -F, which
    # would flash the popup shut on a one-screen diff (same gotcha as
    # _show_judge_report). delta wants an UNcolored diff on stdin.
    color=never; pager="DELTA_PAGER='less -R' delta <"
  else
    color=always; pager="LESS='-R' ${PAGER:-less}"
  fi
  body=$(_wt_diff_raw "$path" "$base" "$color")
  if [ -z "$body" ]; then
    tmux display-message "wtcp: [$wt] has no changes vs ${base:-main}" 2>/dev/null || true
    say "[$wt] has no changes vs ${base:-main}"
    return 0
  fi
  F=$(_diff_file); mkdir -p "$(dirname "$F")"
  printf '=== %s — diff vs %s ===\n\n%s\n' "$wt" "$(_diff_base "$path" "$base")" "$body" > "$F"
  qF=$(_sh_quote "$F")
  # NOTE: no -F on the pager (see _show_judge_report).
  tmux display-popup -E -w "$COCKPIT_POPUP_WIDTH" -h "$COCKPIT_POPUP_HEIGHT" "$pager $qF" 2>/dev/null || true
}
_show_judge_report(){
  local F="${1:-$(_judge_file)}" qF
  [ -s "$F" ] || { tmux display-message "wtcp: no judge report yet" 2>/dev/null || true; return 1; }
  qF=$(_sh_quote "$F")
  # NOTE: no -F — with -F less quits immediately when the report fits one screen,
  # which would make the popup flash and close. Keep it open until the user hits q.
  tmux display-popup -E -w "$COCKPIT_POPUP_WIDTH" -h "$COCKPIT_POPUP_HEIGHT" "LESS='-R' ${PAGER:-less} $qF" 2>/dev/null || true
}
# Collect "score<TAB>worktree" rows from the grid's scored pane borders, best
# score first. Unjudged panes (★ ?) get sort key -1 so they land LAST — '?' is
# text and would otherwise sort ABOVE the numbers under `sort -rn`. Name
# tie-break keeps the order deterministic among equal scores / multiple '?'.
_scored_rows(){   # $1=grid window id
  local cwin="$1" p wt label sc key rows=()
  while IFS= read -r p; do
    wt=$(pane_wt "$p"); [ -n "$wt" ] || continue
    label=$(tmux show-options -pqv -t "$p" @pane_label 2>/dev/null || true)
    case "$label" in *"★ "*) sc="${label##*★ }"; sc="${sc%% *}";; *) sc="";; esac
    case "$sc" in ''|*[!0-9.]*) sc="?";; esac
    key="$sc"; [ "$sc" = "?" ] && key="-1"
    rows+=("$key"$'\t'"$sc"$'\t'"$wt")
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  [ "${#rows[@]}" -gt 0 ] || return 0
  printf '%s\n' "${rows[@]}" | sort -t"$(printf '\t')" -k1,1rn -k3,3 | cut -f2-
}
# Interactive menu over the grid's agents (best score first); selecting one runs
# `wtcp <verb> <worktree>`. No-ops when no client is attached (headless tests)
# or the grid has no agent panes.
_agent_menu(){   # $1=grid window $2=menu title $3=verb (pick|diff)
  local cwin="$1" title="$2" verb="$3" sess
  sess=$(tmux display -p -t "$cwin" '#{session_id}' 2>/dev/null || true)
  [ -n "$sess" ] && tmux list-clients -t "$sess" 2>/dev/null | grep -q . || return 0
  local items=() s n idx=0 key qn lbl
  while IFS=$'\t' read -r s n; do
    idx=$((idx+1)); key="$idx"; [ "$idx" -gt 9 ] && key=""
    qn=$(_sh_quote "$n")
    lbl="★ ${s}  ${n}"; [ "$s" = "?" ] && lbl="★ ?  ${n}  (unjudged)"
    items+=("$lbl" "$key" "run-shell \"$INVOKE_CMD $verb $qn\"")
  done < <(_scored_rows "$cwin")
  [ "${#items[@]}" -gt 0 ] || return 0
  items+=("" "" "" "Cancel" q "")
  tmux display-menu -T "$title" "${items[@]}" 2>/dev/null || true
}
_winner_menu(){ _agent_menu "$1" "wtcp — pick winner to merge" pick; }
_diff_menu(){   _agent_menu "$1" "wtcp — view agent diff" diff; }
_keep_menu(){   _agent_menu "$1" "wtcp — keep agent session (no merge)" keep; }
# The judge's winner, read from the scored pane borders: the 🏆-marked pane
# (comparative scoring), else the highest numeric ★ score (independent-scoring
# fallback stamps no trophy). Empty when nothing has been scored.
_scored_winner(){   # $1=grid window -> worktree name or ""
  local cwin="$1" p wt label
  while IFS= read -r p; do
    wt=$(pane_wt "$p"); [ -n "$wt" ] || continue
    label=$(tmux show-options -pqv -t "$p" @pane_label 2>/dev/null || true)
    case "$label" in *🏆*) printf '%s' "$wt"; return 0;; esac
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  local s n
  while IFS=$'\t' read -r s n; do
    [ "$s" = "?" ] && continue
    printf '%s' "$n"; return 0
  done < <(_scored_rows "$cwin")
  return 0
}

# Fallback: judge each agent independently (used if comparative parsing fails).
_score_independent(){
  local cwin="$1" prompt="$2" base="$3"; shift 3
  local p wt path res rest sc reason model="" summary=""
  for p in "$@"; do
    wt=$(pane_wt "$p"); [ -n "$wt" ] || continue
    path=$(_wt_path "$wt")
    res=$(_judge_one "$path" "$prompt" "$p" "$base")   # "score|reason|model"; model is the last field
    sc="${res%%|*}"; rest="${res#*|}"; model="${rest##*|}"; reason="${rest%|*}"
    tmux set-option -p -t "$p" @pane_label "$wt   ★ $sc"
    tmux set-option -p -t "$p" @judge_reason "$reason"
    summary="${summary}- ${wt}: ${sc}/10\n  - ${reason}\n"
  done
  local F; F=$(_judge_file); mkdir -p "$(dirname "$F")"
  { printf 'Task: %s\n' "${prompt:-(unknown)}"; printf 'Judge model: %s\n\n' "${model:-(unknown)}"; printf 'Rankings:\n%b' "$summary"; } > "$F" 2>/dev/null || true
  _show_judge_report "$F"
}

# Comparative scoring: send ALL agents to the judge in one call so it ranks them
# head-to-head and picks a winner. Score (+winner) on each pane border + a
# popup with the comparison. Falls back to independent scoring if it can't parse.
cmd_score(){
  need_tmux; goto_root
  if [ -z "${COCKPIT_JUDGE_URL:-}" ]; then
    tmux display-message "wtcp: set COCKPIT_JUDGE_URL in ~/.config/wtcp/config to use scoring" 2>/dev/null || true
    die "set COCKPIT_JUDGE_URL in ~/.config/wtcp/config to use scoring"
  fi
  local cwin prompt base; cwin=$(_cur_win)
  prompt=$(tmux show-options -wqv -t "$cwin" @cockpit_prompt 2>/dev/null || true)
  base=$(tmux show-options -wqv -t "$cwin" @cockpit_base 2>/dev/null || true)
  _style_window "$cwin"
  # Collect agent panes (skip the bar/empty panes).
  local p wt names=() panes=() nag=0
  while IFS= read -r p; do
    wt=$(pane_wt "$p")
    if [ -z "$wt" ]; then tmux set-option -p -t "$p" @pane_label "$BAR_KEYS"; continue; fi
    names+=("$wt"); panes+=("$p"); nag=$((nag+1))
    tmux set-option -p -t "$p" @pane_label "$wt   judging..."
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  [ "$nag" -ge 1 ] || { tmux display-message "wtcp: no agents to score" 2>/dev/null; return 0; }

  # Per-agent evidence budget so all agents fit the judge's context window.
  local per=$(( COCKPIT_JUDGE_COMPARE_CHARS / (nag*2) )); [ "$per" -ge 800 ] || per=800
  local i blocks="" path diff out
  for (( i=0; i<nag; i++ )); do
    path=$(_wt_path "${names[i]}")
    [ -n "$path" ] && diff=$(_wt_diff "$path" "$base" | head -c "$per") || diff=""
    out=$(tmux capture-pane -p -S - -t "${panes[i]}" 2>/dev/null | tail -c "$per")
    blocks="${blocks}"$'\n\n'"=== AGENT: ${names[i]} ==="$'\n'"--- Diff vs base (may be empty) ---"$'\n'"${diff}"$'\n'"--- Terminal output ---"$'\n'"${out}"
  done

  local jhdr=(); [ -n "${COCKPIT_JUDGE_AUTH:-}" ] && jhdr+=(-H "Authorization: $COCKPIT_JUDGE_AUTH")
  local instr req resp
  instr="You are a rigorous, skeptical senior engineer comparing several agents that each attempted the SAME task. Compare them head-to-head on correctness, completeness, depth, and actionability. Evaluate BOTH evidence streams for every agent: the code Diff is the source of truth for implementation quality when present, while terminal Output is evidence for tests run, claims made, analysis quality, and whether the agent noticed important issues. For analysis/research tasks with empty diffs, judge the substance and accuracy of the Output and do NOT penalize an empty diff by itself. Be calibrated and discriminating: spread the scores so the ranking is meaningful, reserve 9-10 for genuinely complete and correct work, and penalize wrong claims, vagueness, or unfinished work. Do not reward or penalize Korean vs English language choice unless the task explicitly requires a language. Use only the evidence shown. Return STRICT JSON only, no prose: {\"rankings\":[{\"name\":\"<exact agent name>\",\"score\":N,\"reason\":\"one concise bullet-fragment style comparison reason\"}],\"winner\":\"<exact name>\",\"summary\":\"one concise bullet-fragment style summary of why the winner beat the rest\"}. Include EVERY agent in rankings, best first, name copied EXACTLY. Write all \"reason\" and \"summary\" values in the SAME LANGUAGE as the Task below; keep the JSON keys in English and copy agent names exactly as given."
  req=$(jq -nc --arg s "$instr" --arg t "${prompt:-(unknown task)}" --arg b "$blocks" --arg m "${COCKPIT_JUDGE_MODEL:-}" \
    '{messages:[{role:"user",content:($s + "\n\nTask: " + $t + "\n\nAGENTS (compare these):" + $b)}],max_tokens:700,temperature:0.2} + (if $m == "" then {} else {model:$m} end)')
  local raw model
  raw=$(curl -s --max-time "$COCKPIT_JUDGE_TIMEOUT" "$COCKPIT_JUDGE_URL" -H 'Content-Type: application/json' ${jhdr[@]+"${jhdr[@]}"} -d "$req" 2>/dev/null || true)
  model=$(printf '%s' "$raw" | jq -r '.model // empty' 2>/dev/null || true)
  resp=$(printf '%s' "$raw" | jq -r '.choices[0].message.content // empty' 2>/dev/null || true)

  local winner; winner=$(printf '%s' "$resp" | jq -r '.winner // empty' 2>/dev/null || true)
  if ! printf '%s' "$resp" | jq -e '.rankings[0].name' >/dev/null 2>&1; then
    _score_independent "$cwin" "$prompt" "$base" "${panes[@]}"   # couldn't parse -> per-agent fallback (re-judges, reports its own model)
    _winner_menu "$cwin"
    return 0
  fi

  # Write the comparative report (jq formats the whole file).
  local F; F=$(_judge_file); mkdir -p "$(dirname "$F")"
  printf '%s' "$resp" | jq -r --arg task "${prompt:-(unknown)}" --arg model "${model:-(unknown)}" '
    .winner as $w
    | "Task: \($task)\n"
      + "Judge model: \($model)\n\n"
      + (if $w then "Winner: \($w)\n\n" else "" end)
      + ((.summary // "") | if . != "" then "Summary:\n- " + . + "\n\n" else "" end)
      + "Rankings:\n"
      + ([.rankings[] | "- \(.name): \(.score)/10\(if .name==$w then " (winner)" else "" end)\n  - \(.reason)"] | join("\n"))
  ' > "$F" 2>/dev/null || true

  # Stamp each pane border with its ★score (+🏆 winner).
  local nm sc rs mark
  while IFS=$'\t' read -r nm sc rs; do
    for (( i=0; i<nag; i++ )); do
      [ "${names[i]}" = "$nm" ] || continue
      mark=""; [ "$nm" = "$winner" ] && mark=" 🏆"
      tmux set-option -p -t "${panes[i]}" @pane_label "${names[i]}   ★ ${sc}${mark}"
      tmux set-option -p -t "${panes[i]}" @judge_reason "$rs"
    done
  done < <(printf '%s' "$resp" | jq -r '.rankings[] | [.name,(.score|tostring),.reason] | @tsv' 2>/dev/null)
  # Any agent the judge skipped -> mark unknown so the border isn't stuck on "judging...".
  for (( i=0; i<nag; i++ )); do
    case "$(tmux show-options -pqv -t "${panes[i]}" @pane_label 2>/dev/null)" in
      *"★ "*) ;; *) tmux set-option -p -t "${panes[i]}" @pane_label "${names[i]}   ★ ?";;
    esac
  done

  _show_judge_report "$F" || true
  # Winner is now resolvable non-interactively: `wtcp merge` merges it one-shot.
  [ -n "$winner" ] && say "winner [$winner] — merge it with 'wtcp merge' (prefix Ctrl-R also offers it)"
  # After reading the report, offer a one-key winner pick that merges directly.
  [ "$COCKPIT_NO_INTERACTIVE_MENUS" = "1" ] || _winner_menu "$cwin"
}

# Show or set the agent set compared by `wtcp start` (persists to ~/.config/wtcp/config).
cmd_agents(){
  if [ "$#" -eq 0 ]; then echo "$COCKPIT_AGENTS"; return 0; fi
  [ "$#" -le 6 ] || die "at most 6 agents are supported (got $#)"
  mkdir -p "$(dirname "$WTCP_CONFIG")"
  local val="$*"
  if [ -f "$WTCP_CONFIG" ] && grep -q '^COCKPIT_AGENTS=' "$WTCP_CONFIG"; then
    awk -v v="COCKPIT_AGENTS=\"$val\"" '/^COCKPIT_AGENTS=/{print v;next}{print}' "$WTCP_CONFIG" > "$WTCP_CONFIG.tmp" && mv "$WTCP_CONFIG.tmp" "$WTCP_CONFIG"
  else
    printf 'COCKPIT_AGENTS="%s"\n' "$val" >> "$WTCP_CONFIG"
  fi
  COCKPIT_AGENTS="$val"
  ok "compare set -> $val"
  _ensure_agent_configs
}

_send_to_window(){
  local cwin="$1" text="$2"
  tmux list-panes -t "$cwin" >/dev/null 2>&1 || die "target window not found: $cwin"
  local n=0 p wt
  while IFS= read -r p; do
    wt=$(pane_wt "$p"); [ -n "$wt" ] || continue          # skip the bar/empty pane
    _send_to_pane "$p" "$text"
    printf '  %s->%s %s\n' "$C_DIM" "$C_OFF" "$wt"; n=$((n+1))
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  ok "sent to $n agent(s)"
}

cmd_send(){
  need_tmux
  local text="${1:-}"; [ -n "$text" ] || die 'send "<text>"'
  local cwin; cwin=$(_cur_win)
  _send_to_window "$cwin" "$text"
}

cmd_prompt_send(){
  need_tmux
  local cwin="${1:-}" text
  if [ -z "$cwin" ] || ! tmux list-panes -t "$cwin" >/dev/null 2>&1; then
    cwin=$(_cur_win)
  fi
  if [ -t 0 ]; then
    printf 'send-all: ' > /dev/tty
    IFS= read -r text < /dev/tty || die 'send-all canceled'
  else
    IFS= read -r text || die 'send-all canceled'
  fi
  [ -n "$text" ] || die 'send-all prompt was empty'
  _send_to_window "$cwin" "$text"
}

# Popup prompt -> `wtcp fork` from the focused agent pane. This is how a KEPT
# session fans out again: its window has no shell pane, so prefix Ctrl-F opens
# this popup, and the new round branches from the kept agent's work.
cmd_prompt_fork(){
  need_tmux
  local text
  if [ -t 0 ]; then
    printf 'fork round from this agent — prompt: ' > /dev/tty
    IFS= read -r text < /dev/tty || die 'fork canceled'
  else
    IFS= read -r text || die 'fork canceled'
  fi
  [ -n "$text" ] || die 'fork prompt was empty'
  cmd_fork "$text"
}

cmd_show(){
  need_tmux
  _show_judge_report "$(_judge_file)"
}

# Interactive winner picker for the current grid (menu of scored agents -> merge).
cmd_winner(){
  need_tmux
  local cwin; cwin=$(_cur_win)
  _winner_menu "$cwin"
}

# One-shot "merge the judge's winner": resolve the scored winner from the pane
# borders and hand it to the pick machinery (merge with changes / keep without).
# This is the non-interactive complement to the winner menu — usable from the
# bar, a script, or headless runs, right after `wtcp score`.
cmd_merge(){
  need_tmux
  local cwin winner; cwin=$(_cur_win)
  winner=$(_scored_winner "$cwin")
  if [ -z "$winner" ]; then
    tmux display-message "wtcp: no scored winner — run 'wtcp score' first" 2>/dev/null || true
    die "no scored winner in this grid — run 'wtcp score' first, or 'wtcp pick <name>' to choose manually"
  fi
  say "merging the judge's winner [$winner]"
  cmd_pick "$winner" "$@"   # merge strategy flags (--squash/--rebase/--into) pass through
}

# Full-diff viewer. Worktree from $1 when given (the diff menu passes it),
# else the focused agent pane; from the bar/empty pane, open the agent menu.
cmd_diff(){
  need_tmux
  local wt="${1:-}"
  if [ -z "$wt" ]; then
    wt=$(pane_wt "$(_cur_pane)")
    if [ -z "$wt" ]; then _diff_menu "$(_cur_win)"; return 0; fi
  fi
  _show_diff_popup "$wt"
}

_copy_to_clipboard(){
  local F="$1"
  if command -v pbcopy >/dev/null 2>&1; then pbcopy < "$F"; return 0; fi
  if command -v wl-copy >/dev/null 2>&1; then wl-copy < "$F"; return 0; fi
  if command -v xclip >/dev/null 2>&1; then xclip -selection clipboard < "$F"; return 0; fi
  return 1
}

cmd_copy(){
  local F; F=$(_judge_file)
  [ -s "$F" ] || die "no judge report yet (run 'wtcp score' first)"
  if _copy_to_clipboard "$F"; then
    tmux display-message "wtcp: copied last judge report" 2>/dev/null || true
    ok "copied last judge report"
  else
    cat "$F"
    die "no clipboard command found (need pbcopy, wl-copy, or xclip)"
  fi
}

# workmux merge failed (usually a conflict). Nothing has been removed at this
# point — keep the whole round alive and tell the user how to recover. Depending
# on workmux version/strategy the conflict lands mid-merge in the MAIN worktree,
# mid-rebase in the winner's worktree, or (current workmux) nowhere — it keeps
# the target clean and asks you to rebase the winner's worktree onto the base
# yourself. Detect which and tailor the guidance.
_merge_fail_recover(){   # $1=winner worktree
  local winner="$1" root wpath
  root=$(tmux show-options -wqv -t "$(_cur_win)" @cockpit_root 2>/dev/null || true)
  wpath=$(_wm path "$winner" 2>/dev/null || true)
  # pick usually runs from a keybinding run-shell where stderr is easy to miss.
  tmux display-message "wtcp: merge of [$winner] FAILED — round kept intact (see output)" 2>/dev/null || true
  {
    echo "wtcp: merge of [$winner] failed. NOTHING was removed — all agent worktrees and the grid are intact."
    if [ -n "$root" ] && git -C "$root" rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
      echo "wtcp: the conflict is mid-merge in the MAIN worktree ($root). Either:"
      echo "  - resolve there, 'git add -A && git commit', then run 'wtcp abandon' from the grid"
      echo "    (the merge commit is now on the main branch; abandon just drops the round worktrees), or"
      echo "  - back out with 'git -C $root merge --abort', then pick another agent or fix + re-run 'wtcp pick $winner'."
    elif [ -n "$wpath" ] && [ -d "$(git -C "$wpath" rev-parse --git-path rebase-merge 2>/dev/null)" ]; then
      echo "wtcp: the conflict is mid-rebase in the winner's worktree ($wpath)."
      echo "  Resolve there, 'git rebase --continue', then re-run 'wtcp pick $winner'."
    else
      echo "wtcp: workmux kept the target clean (see its output above). Update the winner's worktree onto the base"
      [ -n "$wpath" ] && echo "  (e.g. 'git -C $wpath rebase <main-branch>'), resolve any conflicts there,"
      echo "  then re-run 'wtcp pick $winner' — or pick another agent, or 'wtcp abandon'."
    fi
  } >&2
}

# Keep ONE agent's live session and dismantle the rest of the round: break its
# pane out into its own window (worktree + running agent survive, nothing is
# merged), remove the other agents' worktrees, close the grid. Made for
# analysis/review rounds — continue the conversation in the kept pane, then
# `wtcp fork "<prompt>"` (prefix Ctrl-F) fans out a new multi-agent round from
# that agent's work, or `wtcp drop` discards it.
_keep_session(){   # $1=grid window  $2=keeper worktree  $3..=loser worktrees
  local cwin="$1" keep="$2"; shift 2
  local kp="" p wt
  while IFS= read -r p; do
    wt=$(pane_wt "$p")
    [ "$wt" = "$keep" ] && { kp="$p"; break; }
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  [ -n "$kp" ] || die "no pane for [$keep] in this grid"
  # Carry the round context onto the kept pane's new window so goto_root, diff,
  # and fork keep working from it (window options don't survive break-pane).
  local root prompt base nwin pcount
  root=$(tmux show-options -wqv -t "$cwin" @cockpit_root 2>/dev/null || true)
  prompt=$(tmux show-options -wqv -t "$cwin" @cockpit_prompt 2>/dev/null || true)
  base=$(tmux show-options -wqv -t "$cwin" @cockpit_base 2>/dev/null || true)
  pcount=$(tmux list-panes -t "$cwin" -F x | grep -c . || true)
  if [ "$pcount" -le 1 ]; then
    # The window already holds ONLY the keeper (keep/pick pressed again in an
    # already-kept window). break-pane can't split a single-pane window — on
    # tmux >= 3.4 it "succeeds" with EMPTY -P output and just renames, which
    # would leave nwin empty and later kill-window would destroy the live
    # session. Keep the window in place instead.
    nwin="$cwin"
    tmux rename-window -t "$cwin" "${WIN_PREFIX}:${keep}" 2>/dev/null || true
  else
    nwin=$(tmux break-pane -d -P -F '#{window_id}' -s "$kp" -n "${WIN_PREFIX}:${keep}" 2>/dev/null) || nwin=""
    [ -n "$nwin" ] || die "could not break [$keep] out of the grid"
  fi
  [ -n "$root" ]   && tmux set-option -w -t "$nwin" @cockpit_root "$root"
  [ -n "$prompt" ] && tmux set-option -w -t "$nwin" @cockpit_prompt "$prompt"
  [ -n "$base" ]   && tmux set-option -w -t "$nwin" @cockpit_base "$base"
  _style_window "$nwin"
  local l
  for l in "$@"; do [ -n "$l" ] && (_wm remove "$l" -f || true); done
  tmux select-window -t "$nwin" 2>/dev/null || true
  _spawn_status_watch "$nwin"
  tmux display-message "wtcp: kept [$keep] — talk to it directly; prefix Ctrl-F forks a new round from it" 2>/dev/null || true
  ok "kept [$keep] (worktree + live session, nothing merged). dropped: ${*:-(none)}"
  say "continue in its pane. prefix Ctrl-F (or 'wtcp fork \"<prompt>\"') fans out a new"
  echo "     multi-agent round from this agent's work; 'wtcp drop' discards it when done."
  # LAST on purpose: keep/pick usually run inside the grid's own bar pane, and
  # killing the grid kills that pane — and this very process with it. Nothing
  # after this line is guaranteed to execute.
  [ "$nwin" = "$cwin" ] || tmux kill-window -t "$cwin" 2>/dev/null || true
}

cmd_keep_menu(){ need_tmux; _keep_menu "$(_cur_win)"; }

# Keep the focused agent (or $1 from the menu/CLI); from the bar pane, open a menu.
cmd_keep(){
  need_tmux
  local cwin keep; cwin=$(_cur_win)
  if [ -n "${1:-}" ]; then
    keep="$1"
  else
    keep=$(pane_wt "$(_cur_pane)")
    if [ -z "$keep" ]; then _keep_menu "$cwin"; return 0; fi
  fi
  local losers=() p wt
  while IFS= read -r p; do
    wt=$(pane_wt "$p"); [ -z "$wt" ] && continue   # skip bar/empty panes
    [ "$wt" = "$keep" ] && continue
    losers+=("$wt")
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  goto_root
  say "keeping [$keep] as a live session (no merge)"
  _keep_session "$cwin" "$keep" "${losers[@]:-}"
}

cmd_pick(){
  need_tmux
  # Winner = first non-flag arg (the winner menu / `wtcp merge` pass it), else
  # the focused pane's agent. workmux merge STRATEGY flags pass through:
  # --squash, --rebase, --into <branch> (see `workmux merge --help`).
  local winner="" mergeargs=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --squash|--rebase) mergeargs+=("$1"); shift ;;
      --into) [ -n "${2:-}" ] || die "pick: --into needs a branch name"; mergeargs+=("$1" "$2"); shift 2 ;;
      --*) die "pick: unknown option $1 (merge flags: --squash --rebase --into <branch>)" ;;
      *) winner="$1"; shift ;;
    esac
  done
  local cwin fp; cwin=$(_cur_win); fp=$(_cur_pane)
  if [ -z "$winner" ]; then
    winner=$(pane_wt "$fp"); [ -n "$winner" ] || die "put the cursor on the winning agent pane (not the bar/empty pane)"
  fi
  local losers=() p wt
  while IFS= read -r p; do
    wt=$(pane_wt "$p"); [ -z "$wt" ] && continue   # skip bar/empty panes
    [ "$wt" = "$winner" ] && continue
    losers+=("$wt")
  done < <(tmux list-panes -t "$cwin" -F '#{pane_id}')
  goto_root
  # Auto-commit the winner's uncommitted changes (workmux merge only takes commits -> else work is lost).
  local wpath base has_changes=1; wpath=$(_wm path "$winner" 2>/dev/null || true)
  if [ -n "$wpath" ] && [ -n "$(git -C "$wpath" status --porcelain 2>/dev/null)" ]; then
    local msg; msg=$(tmux show-options -wqv -t "$cwin" @cockpit_prompt 2>/dev/null || true); [ -n "$msg" ] || msg="wtcp pick: $winner"
    say "auto-committing the winner's uncommitted changes..."
    git -C "$wpath" add -A && git -C "$wpath" commit -q -m "$msg" \
      || die "auto-commit failed for [$winner]; merge aborted so the worktree is preserved"
  fi
  base=$(tmux show-options -wqv -t "$cwin" @cockpit_base 2>/dev/null || true)
  if [ -n "$wpath" ] && [ -n "$base" ] && git -C "$wpath" rev-parse --verify -q "$base^{commit}" >/dev/null 2>&1; then
    if git -C "$wpath" diff --quiet "$base" -- 2>/dev/null && [ -z "$(git -C "$wpath" status --porcelain 2>/dev/null)" ]; then
      has_changes=0
    fi
  fi
  # Analysis/research round (no code changes vs base): nothing to merge — keep
  # the winner as a LIVE session instead so the conversation continues (its
  # scrollback holds the analysis; workmux merge would error on the empty branch).
  if [ "$has_changes" -eq 0 ]; then
    say "winner [$winner] has no code changes vs base -> keeping its session (no merge)."
    _keep_session "$cwin" "$winner" "${losers[@]:-}"
    return 0
  fi
  say "winner [$winner] -> merge${mergeargs[0]:+ (${mergeargs[*]})} to workmux main branch / cleanup: ${losers[*]:-(none)}"
  _wm merge "$winner" ${mergeargs[@]+"${mergeargs[@]}"} || { _merge_fail_recover "$winner"; exit 1; }
  local l; for l in "${losers[@]:-}"; do [ -n "$l" ] && (_wm remove "$l" -f || true); done
  ok "done. merged winner — keep working or start another round."
  # LAST on purpose (see _keep_session): closing the grid can kill this very
  # process when pick was typed in the bar pane. Only wtcp-owned (wt:*) windows
  # are closed — `wtcp pick <name>` from a plain shell window must not kill it.
  case "$(tmux display -p -t "$cwin" '#{window_name}' 2>/dev/null)" in
    "${WIN_PREFIX}:"*) tmux kill-window -t "$cwin" 2>/dev/null || true ;;
  esac
}

cmd_drop(){
  need_tmux
  local fp wt; fp=$(_cur_pane); wt=$(pane_wt "$fp")
  [ -n "$wt" ] || die "put the cursor on the agent pane to drop (not the bar/empty pane)"
  goto_root
  say "dropping [$wt] (remove worktree + close pane, grid re-tiles)"
  _wm remove "$wt" -f || true
  tmux kill-pane -t "$fp" 2>/dev/null || true     # only the top grid re-flows; the bottom bar stays
}

cmd_setup(){
  need_tmux
  # Bind each verb to BOTH the bare uppercase letter and Ctrl+lowercase. The
  # Ctrl+letter variant passes through the Korean IME (the bare letters get
  # composed into Hangul), so prefix -> C-p etc. work without switching input.
  local k
  for k in P C-p; do tmux bind-key "$k" run-shell "$INVOKE_CMD pick"; done
  for k in K C-k; do tmux bind-key "$k" run-shell "$INVOKE_CMD keep"; done
  for k in X C-x; do tmux bind-key "$k" run-shell "$INVOKE_CMD drop"; done
  for k in R C-r; do
    tmux bind-key "$k" display-menu -T "wtcp review" \
      "Run LLM judge (score all)" r "run-shell \"$INVOKE_CMD score\"" \
      "Merge the scored winner" m "run-shell \"$INVOKE_CMD merge\"" \
      "Pick winner to merge (menu)" p "run-shell \"$INVOKE_CMD winner\"" \
      "Keep a session (no merge)" k "run-shell \"$INVOKE_CMD keep-menu\"" \
      "View agent diff" d "run-shell \"$INVOKE_CMD diff\"" \
      "Show last result" v "run-shell \"$INVOKE_CMD show\"" \
      "Copy last result" c "run-shell \"$INVOKE_CMD copy\"" \
      "" "" "" \
      "Cancel" q ""
  done
  for k in S C-s; do tmux bind-key "$k" display-popup -E "$INVOKE_CMD prompt-send"; done
  for k in F C-f; do tmux bind-key "$k" display-popup -E "$INVOKE_CMD prompt-fork"; done
  # Make the small grid panes reviewable: mouse-wheel scroll + vi paging
  # (Ctrl-U/Ctrl-D half page, Ctrl-B/Ctrl-F full page) in copy-mode.
  # `mouse on` is tmux >= 2.1; fall back to the pre-2.1 mode-* options so very old
  # tmux still gets click-to-select + wheel scroll. (If the mouse still doesn't
  # work, it's the terminal/session layer, not this — see `wtcp doctor`.)
  tmux set -g mouse on 2>/dev/null \
    || { tmux set -g mode-mouse on 2>/dev/null; tmux set -g mouse-select-pane on 2>/dev/null; tmux set -g mouse-select-window on 2>/dev/null; } \
    || true
  tmux setw -g mode-keys vi
  local copy_cmd=""
  if command -v pbcopy >/dev/null 2>&1; then copy_cmd="pbcopy"
  elif command -v wl-copy >/dev/null 2>&1; then copy_cmd="wl-copy"
  elif command -v xclip >/dev/null 2>&1; then copy_cmd="xclip -selection clipboard"
  fi
  if [ -n "$copy_cmd" ]; then
    tmux bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "$copy_cmd" 2>/dev/null || true
    tmux bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "$copy_cmd" 2>/dev/null || true
    tmux bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "$copy_cmd" 2>/dev/null || true
  else
    tmux bind-key -T copy-mode-vi y send-keys -X copy-selection-and-cancel 2>/dev/null || true
    tmux bind-key -T copy-mode-vi Enter send-keys -X copy-selection-and-cancel 2>/dev/null || true
  fi
  # Wheel over ANY pane (focused or not) must scroll THAT pane: every command
  # targets the pane under the mouse (-t=). Mouse-aware TUIs (claude/codex
  # report mouse -> mouse_any_flag) get the wheel events natively so their own
  # viewport scrolls; other panes enter tmux copy-mode and scroll the history.
  # (The old binding forced copy-mode even over mouse-aware TUIs, and on older
  # tmux could scroll the ACTIVE pane instead of the hovered one.)
  tmux bind-key -n WheelUpPane "if-shell -Ft= '#{||:#{pane_in_mode},#{mouse_any_flag}}' 'send-keys -M' 'copy-mode -e -t= ; send-keys -M'" 2>/dev/null || true
  # Click on an inactive pane focuses it AND forwards the click to the app there
  # (tmux's default; re-bound explicitly so a user config override can't break
  # click-to-focus in the grid).
  tmux bind-key -n MouseDown1Pane 'select-pane -t= ; send-keys -M' 2>/dev/null || true
  # Keep lots of scrollback so `wtcp score` can feed the judge each agent's whole
  # session (set before the agent panes are created, so they inherit it).
  tmux set -g history-limit 100000
  ok "keybindings -> prefix, then  Ctrl-P pick  ·  Ctrl-K keep  ·  Ctrl-X drop  ·  Ctrl-S send-all  ·  Ctrl-F fork  ·  Ctrl-R review menu"
  printf '%s\n' \
    "  ${C_DIM}Use Ctrl + the letter (works with the Korean IME). Ctrl-R runs the judge, merges the winner, shows reports.${C_OFF}" \
    "  ${C_DIM}Move/resize: prefix+arrow = move (o = cycle) · prefix+z = fullscreen one (z to return) · prefix+Ctrl-arrow = resize.${C_OFF}" \
    "  ${C_DIM}Scroll/copy: mouse wheel, or prefix+[ then Ctrl-U/Ctrl-D; y/Enter copies selection when a clipboard tool exists.${C_OFF}"
}

# Jump to the active grid window (overlay-like "button"). Most recent one.
cmd_grid(){
  need_tmux
  local w; w=$(tmux list-windows -F '#{window_id} #{window_name}' | awk -v p="^${WIN_PREFIX}:" '$2 ~ p{print $1}' | tail -1)
  [ -n "$w" ] || die "no active grid (run 'wtcp start' first)"
  tmux select-window -t "$w"
}

# Environment / compatibility check. Prints what wtcp depends on so you can see
# why the grid, mouse, or per-pane scroll misbehaves on a given machine/terminal.
# Safe to run anywhere (does not need to be inside a grid).
cmd_doctor(){
  echo "wtcp doctor — environment check"
  echo
  local tv; tv=$(tmux -V 2>/dev/null | awk '{print $2}' || true)
  printf '  tmux             %s\n' "${tv:-(not found)}"
  if [ -n "${TMUX:-}" ]; then
    printf '  inside tmux      yes\n'
    printf '  mouse            %s   (need: on)\n' "$(tmux show -gv mouse 2>/dev/null || echo '?')"
    printf '  mode-keys        %s\n' "$(tmux show -gwv mode-keys 2>/dev/null || echo '?')"
    printf '  history-limit    %s\n' "$(tmux show -gv history-limit 2>/dev/null || echo '?')"
    local ct; ct=$(tmux display -p '#{client_termname}' 2>/dev/null || true)
    printf '  client TERM      %s\n' "${ct:-(no client attached)}"
    case "$ct" in
      "")            printf '  nesting          (attach a client to judge nesting)\n';;
      screen*|tmux*) printf '  nesting          LIKELY NESTED (client runs inside another tmux/screen).\n                   Mouse often will not reach this inner tmux. Detach the outer\n                   tmux or connect from a bare terminal, then re-run.\n';;
      *)             printf '  nesting          no (single tmux layer)\n';;
    esac
  else
    printf '  inside tmux      NO  — run wtcp inside a tmux session\n'
  fi
  printf '  TERM             %s\n' "${TERM:-(unset)}"
  echo
  printf '  invoke (keys)    %s\n' "$INVOKE"
  printf '  wtcp config      %s\n' "$( [ -f "$WTCP_CONFIG" ] && echo "$WTCP_CONFIG" || echo "(none — using defaults)" )"
  printf '  judge url        %s\n' "${COCKPIT_JUDGE_URL:-(unset; scoring disabled)}"
  printf '  judge model      %s\n' "${COCKPIT_JUDGE_MODEL:-(unset)}"
  printf '  agents           %s\n' "$COCKPIT_AGENTS"
  local a p cmd kind
  for a in $COCKPIT_AGENTS; do
    kind=$(_agent_kind "$a")
    if [ -n "$(_agent_cmd "$a")" ]; then
      printf '    %-14s custom cmd (%s): %s\n' "$a" "$kind" "$(_agent_cmd "$a")"
      continue
    fi
    cmd=$(_agent_launch_cmd "$a")
    if [ -n "$cmd" ]; then   # derived (trust flags and/or COCKPIT_AGENT_<ALIAS>_MODEL)
      p=$(command -v "${cmd%% *}" 2>/dev/null || true)
      printf '    %-14s %s%s\n' "$a" "$cmd" "${p:+   (${p})}"
      [ -n "$p" ] || printf '    %-14s ^ CLI %s not on PATH\n' "" "${cmd%% *}"
      continue
    fi
    p=$(command -v "$a" 2>/dev/null || true)
    if [ -n "$p" ]; then printf '    %-14s %s\n' "$a" "$p"
    else printf '    %-14s not on PATH (ok if custom/defined in ~/.config/workmux/config.yaml; kind=%s)\n' "$a" "$kind"; fi
  done
  echo
  local t miss=""
  for t in tmux workmux git jq curl; do command -v "$t" >/dev/null 2>&1 || miss="$miss$t "; done
  if [ -n "$miss" ]; then printf '  deps             MISSING: %s\n' "$miss"
  else printf '  deps             tmux workmux git jq curl (all present)\n'; fi
  echo
  echo "  Mouse / per-pane scroll / keys misbehaving? Detach tmux (prefix d) and"
  echo "  re-run 'wtcp start' (or 'wtcp setup'). A long-lived session can leave the"
  echo "  terminal's mouse-reporting state stale; detaching re-initializes it. This"
  echo "  is the usual fix when the same setup works on one machine but not another."
}

cmd_list(){ _wm list; }

cmd_help(){
  local T="$C_TAG" B="$C_BOLD" D="$C_DIM" O="$C_OFF"
  cat <<EOF
${T}wtcp${O} ${B}— Worktree Cockpit${O}
  Run several coding agents on ONE prompt in an isolated tmux grid, then
  review, score, and merge (or keep) the best.   ${D}workmux + tmux + git${O}

${B}START A ROUND${O}                                                      ${D}alias  in-grid key${O}
  wtcp start "<prompt>" [name]  one worktree per agent + broadcast + grid  ${D}b${O}
  wtcp agents [names...]        show/set the compared agents ${D}(max 6)${O}

${B}REVIEW & FINISH${O}
  wtcp score            LLM judge ranks all agents + names a winner       ${D}r      prefix Ctrl-R${O}
  wtcp merge            merge the judge's winner ${D}(one shot, no menu)${O}      ${D}m      prefix Ctrl-R${O}
                        ${D}pick/merge take workmux flags: --squash · --rebase · --into <branch>${O}
  wtcp winner           menu of scored agents -> merge the choice         ${D}       prefix Ctrl-R${O}
  wtcp pick             merge the FOCUSED agent, drop the rest            ${D}p      prefix Ctrl-P${O}
                        ${D}winner has no code changes? -> keeps the session${O}
  wtcp keep [name]      keep ONE live session (no merge), drop the rest   ${D}k      prefix Ctrl-K${O}
  wtcp send "<text>"    send a follow-up line to every agent              ${D}s      prefix Ctrl-S${O}
  wtcp fork "<prompt>"  new round branched from the focused agent's WIP   ${D}f      prefix Ctrl-F${O}
  wtcp diff [name]      an agent's FULL diff vs the round base (popup)    ${D}       prefix Ctrl-R${O}
  wtcp show / copy      last judge report: popup / clipboard              ${D}cp${O}
  wtcp drop             remove just the focused agent (grid re-tiles)     ${D}x      prefix Ctrl-X${O}
  wtcp abandon          discard the whole grid, merge nothing             ${D}a${O}

${B}WORKSPACE${O}
  wtcp grid             jump to the newest wtcp window                    ${D}g${O}
  wtcp list             list active worktrees                             ${D}ls${O}
  wtcp clean            remove ALL compare worktrees + wtcp windows       ${D}clear${O}
  wtcp setup            (re)install in-grid keys + mouse ${D}(start does this)${O}
  wtcp doctor           environment check: tmux/mouse/agents/deps + tips

${B}IN-GRID KEYS${O}  ${D}press your tmux prefix first — Ctrl+letter passes the Korean IME${O}
  Ctrl-P pick·merge   Ctrl-K keep   Ctrl-X drop   Ctrl-S send-all   Ctrl-F fork   Ctrl-R review menu
  z fullscreen (z returns)  ·  arrows move / o cycle  ·  [ scroll+copy  ·  mouse: click focus, wheel scroll

${B}CONFIG${O}  ~/.config/wtcp/config   ${D}(sourced shell vars — template: wtcp.config.example)${O}
  COCKPIT_AGENTS="claude codex opencode"          ${D}the compared agent set${O}
  COCKPIT_AGENT_<ALIAS>_MODEL="opus"              ${D}same CLI, different model (claude/codex/opencode)${O}
  COCKPIT_AGENT_<ALIAS>_CMD="env ... claude"      ${D}full command: other backends (e.g. GLM endpoint)${O}
  COCKPIT_JUDGE_URL / _MODEL / _AUTH              ${D}OpenAI-compatible judge endpoint for 'wtcp score'${O}
  ${D}'wtcp doctor' prints the exact launch command per agent and the live tmux state.${O}
EOF
}

cmd_clean(){
  need_repo
  say "removing all worktrees (except main) + closing grid windows..."
  # 1) Remove worktrees FIRST. cmd_clean is often run from the grid's bottom bar
  #    pane; step 2 kills that window — which would terminate this script before
  #    the removal ran (the old "have to run clean twice" bug). Do removal first
  #    so it always completes even if killing our own window ends the script.
  _wm remove --all -f
  # 2) Close any leftover grid windows (their joined panes aren't workmux-tracked
  #    so `remove` can't close them). Kill the window we're in LAST.
  local w cur; cur=$(_cur_win 2>/dev/null || true)
  while IFS= read -r w; do
    [ -n "$w" ] && [ "$w" != "$cur" ] && tmux kill-window -t "$w" 2>/dev/null || true
  done < <(tmux list-windows -F '#{window_id} #{window_name}' 2>/dev/null | awk -v p="^${WIN_PREFIX}:" '$2 ~ p{print $1}')
  case "$(tmux display -p '#{window_name}' 2>/dev/null || true)" in
    "${WIN_PREFIX}:"*) tmux kill-window -t "$cur" 2>/dev/null || true ;;
  esac
}

# Short aliases match the in-grid keybinding letters (b=start, s/p/f/x/a/g/r).
case "${1:-}" in
  start|broadcast|b) shift; cmd_broadcast "$@";;
  send|s)            shift; cmd_send "$@";;
  prompt-send)       shift; cmd_prompt_send "$@";;
  prompt-fork)       shift; cmd_prompt_fork "$@";;
  pick|p)            shift; cmd_pick "$@";;
  keep|k)            shift; cmd_keep "$@";;
  keep-menu)         shift; cmd_keep_menu "$@";;
  fork|f)            shift; cmd_fork "$@";;
  drop|x)            shift; cmd_drop "$@";;
  abandon|a)         shift; cmd_abandon "$@";;
  grid|g)            shift; cmd_grid "$@";;
  score|r)           shift; cmd_score "$@";;
  winner)            shift; cmd_winner "$@";;
  merge|m)           shift; cmd_merge "$@";;
  diff)              shift; cmd_diff "$@";;
  show)              shift; cmd_show "$@";;
  copy|cp)           shift; cmd_copy "$@";;
  agents)            shift; cmd_agents "$@";;
  setup)             shift; cmd_setup "$@";;
  bar-banner)        shift; cmd_bar_banner "$@";;
  status-watch)      shift; cmd_status_watch "$@";;
  doctor)            shift; cmd_doctor "$@";;
  list|ls)           shift; cmd_list "$@";;
  clean|clear)       shift; cmd_clean "$@";;
  ""|-h|--help|help) cmd_help;;
  *) die "unknown command: $1 (try: wtcp help)";;
esac
