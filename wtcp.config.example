# wtcp config — copy to ~/.config/wtcp/config and edit. Everything is optional;
# defaults are shown. `wtcp agents ...` writes COCKPIT_AGENTS here for you.

# Agents compared by `wtcp start` (space-separated). Builtin workmux agents:
# claude codex opencode gemini. Others (e.g. agy) are auto-configured by wtcp.
COCKPIT_AGENTS="claude codex opencode"

# To compare the same CLI with different models/backends, give each variant a
# unique agent alias and map it to a command. Alias names become branch suffixes,
# so keep them shell/git friendly: letters, numbers, dash, underscore.
# Example:
# COCKPIT_AGENTS="claude-sonnet claude-mlx codex-gpt5 codex-mlx"
# COCKPIT_AGENT_CLAUDE_SONNET_CMD="claude --model sonnet"
# COCKPIT_AGENT_CLAUDE_MLX_CMD="claude --model mlx"
# COCKPIT_AGENT_CODEX_GPT5_CMD="codex --model gpt-5"
# COCKPIT_AGENT_CODEX_MLX_CMD="codex --model mlx"
# If the alias does not start with claude/codex/agy, set its kind for trust setup:
# COCKPIT_AGENT_MY_ALIAS_KIND="codex"

# LLM judge endpoint used by `wtcp score`.
# Set this to any OpenAI-compatible /chat/completions URL you actually run.
# Examples:
#   local server:  COCKPIT_JUDGE_URL="http://localhost:<port>/v1/chat/completions"
#   hosted API:    COCKPIT_JUDGE_URL="https://api.example.com/v1/chat/completions"
COCKPIT_JUDGE_URL=""

# Model name sent to the judge endpoint. Most OpenAI-compatible servers require
# this. Leave empty only if your endpoint supplies a default model server-side.
COCKPIT_JUDGE_MODEL=""

# Authorization header for hosted endpoints that need an API key (the namer
# reuses it). Leave empty for local servers. Example:
# COCKPIT_JUDGE_AUTH="Bearer sk-..."
COCKPIT_JUDGE_AUTH=""

# How much context the judge sees. `wtcp score` compares ALL agents in one call;
# COMPARE_CHARS is the total evidence budget split across them. OUTPUT/DIFF_CHARS
# bound a single agent. Raise for a bigger-context judge, lower for a small local
# one (char ~ 1/3-1/4 token; keep the total under the model's window).
COCKPIT_JUDGE_OUTPUT_CHARS=16000
COCKPIT_JUDGE_DIFF_CHARS=16000
COCKPIT_JUDGE_COMPARE_CHARS=48000
COCKPIT_JUDGE_TIMEOUT=120

# Launch polling. 0 = auto, currently generous enough for cold project hooks
# such as per-worktree pnpm install. Set a larger number for very slow hooks.
COCKPIT_LAUNCH_TIMEOUT=0

# Judge/detail popup size inside tmux.
COCKPIT_POPUP_WIDTH="92%"
COCKPIT_POPUP_HEIGHT="85%"

# Branch-name generator from the prompt: fm (Apple Intelligence, macOS, on-device)
# | mlx (OpenAI-compatible endpoint) | off (ASCII slug of the prompt).
COCKPIT_NAMER="fm"
# By default, namer endpoint/model/auth inherit the judge settings above.
# Override only when branch naming should use a different endpoint/model.
COCKPIT_NAMER_URL=""
COCKPIT_NAMER_MODEL=""

# OPT-IN. 1 = auto-start brand-new projects: pre-seed each agent's folder-trust
# store (so "Do you trust this folder?" is skipped) AND launch in an unattended
# permission mode (claude --permission-mode auto; codex bypass). Edits the agents'
# trust stores + the global workmux config, so it is OFF by default. Trusted repos only.
COCKPIT_TRUST=0
# Override how claude/codex launch under COCKPIT_TRUST=1 (defaults shown):
# COCKPIT_CLAUDE_CMD="claude --permission-mode auto"
# COCKPIT_CODEX_CMD="codex --dangerously-bypass-approvals-and-sandbox"
