# wtcp config — copy to ~/.config/wtcp/config and edit. Everything is optional;
# defaults are shown. `wtcp agents ...` writes COCKPIT_AGENTS here for you.

# Agents compared by `wtcp start` (space-separated). Builtin workmux agents:
# claude codex opencode gemini. Others (e.g. agy) are auto-configured by wtcp.
COCKPIT_AGENTS="claude codex opencode"

# To compare the same CLI with different MODELS, give each variant a unique
# alias and set its model — wtcp launches the alias kind's CLI with --model.
# Works for any CLI that takes --model (claude, codex, opencode: provider/model).
# Alias names become branch suffixes, so keep them shell/git friendly.
# Example (same CLI, different models):
# COCKPIT_AGENTS="claude-fable claude-opus codex-gpt5 opencode-glm"
# COCKPIT_AGENT_CLAUDE_FABLE_MODEL="fable"
# COCKPIT_AGENT_CLAUDE_OPUS_MODEL="opus"
# COCKPIT_AGENT_CODEX_GPT5_MODEL="gpt-5"
# COCKPIT_AGENT_OPENCODE_GLM_KIND="opencode"
# COCKPIT_AGENT_OPENCODE_GLM_MODEL="zai-coding-plan/glm-5.2"
#
# For a different BACKEND / env vars / extra flags, map the alias to a full
# command instead (wins over _MODEL). E.g. Claude Code on Zhipu's GLM endpoint
# (any Anthropic-compatible API works the same way):
# COCKPIT_AGENTS="claude-fable claude-glm"
# COCKPIT_AGENT_CLAUDE_GLM_CMD="env ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic ANTHROPIC_AUTH_TOKEN=sk-... ANTHROPIC_MODEL=glm-5.2 claude"
#
# If the alias does not start with claude/codex/agy, set its kind (trust setup +
# the CLI that _MODEL launches):
# COCKPIT_AGENT_MY_ALIAS_KIND="codex"

# Agents that workmux can't prompt-inject: wtcp types the prompt into their pane
# via tmux send-keys instead. Empty by default (agy launches via a wrapper that
# loads the prompt itself). SEND_DELAY is the pause between paste and Enter
# (avoids the codex submit race); AGY_DELAY the wait before send-keys delivery.
# COCKPIT_SENDKEYS_AGENTS=""
# COCKPIT_SEND_DELAY=0.4
# COCKPIT_AGY_DELAY=4

# LLM judge endpoint used by `wtcp score`.
# Set this to any OpenAI-compatible /chat/completions URL you actually run.
# Examples:
#   local server:  COCKPIT_JUDGE_URL="http://localhost:<port>/v1/chat/completions"
#   hosted API:    COCKPIT_JUDGE_URL="https://api.example.com/v1/chat/completions"
COCKPIT_JUDGE_URL=""

# Model name sent to the judge endpoint. Most OpenAI-compatible servers require
# this. Leave empty only if your endpoint supplies a default model server-side.
COCKPIT_JUDGE_MODEL=""

# Authorization header for hosted endpoints that need an API key (the namer
# reuses it). Leave empty for local servers. Example:
# COCKPIT_JUDGE_AUTH="Bearer sk-..."
COCKPIT_JUDGE_AUTH=""

# How much context the judge sees. `wtcp score` compares ALL agents in one call;
# COMPARE_CHARS is the total evidence budget split across them. OUTPUT/DIFF_CHARS
# bound a single agent. Raise for a bigger-context judge, lower for a small local
# one (char ~ 1/3-1/4 token; keep the total under the model's window).
COCKPIT_JUDGE_OUTPUT_CHARS=16000
COCKPIT_JUDGE_DIFF_CHARS=16000
COCKPIT_JUDGE_COMPARE_CHARS=48000
COCKPIT_JUDGE_TIMEOUT=120

# Launch polling. 0 = auto, currently generous enough for cold project hooks
# such as per-worktree pnpm install. Set a larger number for very slow hooks.
COCKPIT_LAUNCH_TIMEOUT=0

# Live agent status on the grid pane borders: ⚡ output changing (working),
# 💬 quiet (waiting for input / done). 0 disables the background watcher.
# COCKPIT_STATUS=1
# COCKPIT_STATUS_INTERVAL=3
# COCKPIT_STATUS_IDLE=6

# Judge/detail popup size inside tmux.
COCKPIT_POPUP_WIDTH="92%"
COCKPIT_POPUP_HEIGHT="85%"

# Branch-name generator from the prompt: fm (Apple Intelligence, macOS, on-device)
# | mlx (OpenAI-compatible endpoint) | off (ASCII slug of the prompt).
COCKPIT_NAMER="fm"
# By default, namer endpoint/model/auth inherit the judge settings above.
# Override only when branch naming should use a different endpoint/model.
COCKPIT_NAMER_URL=""
COCKPIT_NAMER_MODEL=""
# COCKPIT_NAMER_AUTH=""
# Path to the on-device FM helper binary (default: assets/fm-helper/wtcp-fm-helper
# next to the wtcp script; install.sh builds it on macOS).
# COCKPIT_FM_HELPER=""
# Optional warm Apple-Intelligence endpoint (AgentDeck daemon). Port defaults to
# ~/.agentdeck/daemon.json httpPort, then 9120; URL to http://127.0.0.1:<port>.
# COCKPIT_DAEMON_PORT=""
# COCKPIT_DAEMON_URL=""

# OPT-IN. 1 = auto-start brand-new projects: pre-seed each agent's folder-trust
# store (so "Do you trust this folder?" is skipped) AND launch in an unattended
# permission mode (claude --permission-mode auto; codex bypass). Edits the agents'
# trust stores + the global workmux config, so it is OFF by default. Trusted repos only.
COCKPIT_TRUST=0
# Override how claude/codex launch under COCKPIT_TRUST=1 (defaults shown):
# COCKPIT_CLAUDE_CMD="claude --permission-mode auto"
# COCKPIT_CODEX_CMD="codex --dangerously-bypass-approvals-and-sandbox"

# 1 = never auto-open the winner menu after scoring (headless runs / tests).
# COCKPIT_NO_INTERACTIVE_MENUS=0

# Command prefix the in-grid keybindings call back through (default: `wtcp` on
# PATH, else this script's absolute path). Set for wrappers, e.g.:
# COCKPIT_INVOKE="env WTCP_CONFIG=$HOME/.config/wtcp/config /path/to/wtcp"
